def import_rapid_revenue_upload(
    financial_year: str,
    workbook: UploadFile,
    stored_filename: str,
    stored_path: Path,
) -> dict[str, Any]:
    ensure_postgres_schema()
    parsed_workbook = parse_rapid_revenue_workbook(stored_path)
    if not parsed_workbook.rows:
        raise HTTPException(
            status_code=400,
            detail="No rows matching the rapid revenue workbook format were found.",
        )

    upload_id = str(uuid4())
    uploaded_at = utc_now_iso()
    inserted_rows = len(parsed_workbook.rows)
    upload_record = {
        "id": upload_id,
        "financialYear": financial_year,
        "originalFilename": workbook.filename,
        "storedFilename": stored_filename,
        "contentType": workbook.content_type or "application/octet-stream",
        "sizeBytes": stored_path.stat().st_size,
        "uploadedAt": uploaded_at,
        "importedRows": inserted_rows,
        "parsedSheets": parsed_workbook.parsed_sheets,
        "matchedColumns": parsed_workbook.matched_columns,
        "active": True,
        "datasetType": UPLOAD_DATASET_TYPE,
    }

    insert_columns = [
        "upload_id",
        "financial_year",
        "source_sheet",
        "source_row_number",
        "raw_payload",
        *RAPID_REVENUE_COLUMN_KEYS,
    ]
    insert_sql = f"""
        insert into rapid_revenue_records ({", ".join(insert_columns)})
        values ({", ".join(["%s", "%s", "%s", "%s", "%s::jsonb", *["%s"] * len(RAPID_REVENUE_COLUMN_KEYS)])})
    """

    with open_database_connection(require=True) as connection:
        assert connection is not None
        with connection.cursor() as cursor:
            cursor.execute(
                "update rapid_revenue_uploads set is_active = false where financial_year = %s and is_active = true",
                (financial_year,),
            )
            cursor.execute(
                """
                insert into rapid_revenue_uploads (
                    id,
                    financial_year,
                    source_dataset_type,
                    source_upload_id,
                    original_filename,
                    stored_filename,
                    content_type,
                    size_bytes,
                    uploaded_at,
                    imported_rows,
                    parsed_sheets,
                    matched_columns,
                    is_active
                )
                values (%s, %s, %s, %s::uuid, %s, %s, %s, %s, %s::timestamptz, %s, %s, %s, true)
                """,
                (
                    upload_record["id"],
                    upload_record["financialYear"],
                    UPLOAD_DATASET_TYPE,
                    None,
                    upload_record["originalFilename"],
                    upload_record["storedFilename"],
                    upload_record["contentType"],
                    upload_record["sizeBytes"],
                    upload_record["uploadedAt"],
                    upload_record["importedRows"],
                    upload_record["parsedSheets"],
                    upload_record["matchedColumns"],
                ),
            )

            batch: list[list[Any]] = []
            for parsed_row in parsed_workbook.rows:
                batch.append(
                    [
                        upload_id,
                        financial_year,
                        parsed_row.sheet_name,
                        parsed_row.row_number,
                        json.dumps(parsed_row.raw_payload),
                        *[
                            parsed_row.values.get(column_key)
                            for column_key in RAPID_REVENUE_COLUMN_KEYS
                        ],
                    ]
                )
                if len(batch) >= UPLOAD_INSERT_BATCH_SIZE:
                    cursor.executemany(insert_sql, batch)
                    batch.clear()

            if batch:
                cursor.executemany(insert_sql, batch)
        connection.commit()

    return upload_record


def get_rapid_revenue_rows(filters: dict[str, Any] | None = None) -> list[dict[str, Any]]:
    filters = filters or {}
    ensure_postgres_schema()
    ensure_budget_sync_to_rapid_revenue(filters.get("financialYear"))
    where_sql, params = _build_where_clause(filters)
    select_columns = [
        "r.id",
        "u.id::text as upload_id",
        "u.uploaded_at",
        *[f"r.{field.key}" for field in RAPID_REVENUE_FIELD_SPECS],
    ]

    sql = f"""
        select {", ".join(select_columns)}
        from rapid_revenue_records r
        join rapid_revenue_uploads u on u.id = r.upload_id
        where u.is_active = true {where_sql}
        order by r.practice_head nulls last, r.bdm nulls last, r.customer_name nulls last, r.resource_name nulls last
    """

    with open_database_connection(require=True) as connection:
        assert connection is not None
        with connection.cursor() as cursor:
            cursor.execute(sql, params)
            rows = cursor.fetchall()

    return [_serialize_public_row(row) for row in rows]


