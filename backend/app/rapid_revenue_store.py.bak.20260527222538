def _resolve_requested_scope_values(
    requested: list[str],
    allowed: list[str],
) -> list[str]:
    requested_values = [
        str(value).strip()
        for value in requested
        if str(value).strip()
    ]
    allowed_values = [
        str(value).strip()
        for value in allowed
        if str(value).strip()
    ]
    if not allowed_values:
        return requested_values
    if not requested_values:
        return allowed_values

    allowed_map = {
        value.lower(): value
        for value in allowed_values
    }
    merged = [
        allowed_map[value.lower()]
        for value in requested_values
        if value.lower() in allowed_map
    ]
    return list(dict.fromkeys(merged))


def _clean_text(value: Any) -> str:
    return str(value or "").strip()


def _coerce_holiday_date(value: Any) -> date:
    if isinstance(value, datetime):
        return value.date()
    if isinstance(value, date):
        return value

    text = _clean_text(value)
    if not text:
        raise HTTPException(status_code=400, detail="Holiday date is required for every holiday row.")

    for fmt in CUSTOMER_HOLIDAY_DATE_FORMATS:
        try:
            return datetime.strptime(text, fmt).date()
        except ValueError:
            continue
    raise HTTPException(status_code=400, detail=f"Invalid holiday date: {text}.")


