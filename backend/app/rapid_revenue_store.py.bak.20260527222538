    financial_year: str | None = None,
    preview_drafts: bool = False,
    submitter_role_id: str | None = None,
    include_all_months: bool = False,
) -> dict[str, Any]:
    ensure_postgres_schema()
    ensure_budget_sync_to_rapid_revenue(financial_year)
    control = get_forecast_control_settings()
    month_label = (
        forecast_month
        or str(control.get("activeMonth") or control.get("rolloutStartMonth") or "").strip()
        or resolve_current_forecast_month()
    )
    if month_label not in MONTH_KEY_BY_LABEL:
        month_label = str(control.get("activeMonth") or DEFAULT_ROLLOUT_START_MONTH)
    month_key = MONTH_KEY_BY_LABEL.get(month_label)
    if not month_key:
        raise HTTPException(status_code=400, detail="Choose a supported forecast month.")
    draft_role_id = _resolve_submitter_role_id(submitter_role_id) if preview_drafts else ""

    effective_bdms = _resolve_requested_scope_values(
        requested=bdm_filters or [],
        allowed=bdm_names,
    )
    effective_practice_heads = _resolve_requested_scope_values(
        requested=practice_head_filters or [],
        allowed=practice_head_names or [],
    )
    filters: dict[str, Any] = {}
    if effective_bdms:
        filters["bdms"] = effective_bdms
    if effective_practice_heads:
        filters["practiceHeads"] = effective_practice_heads
    if geo_head_names:
        filters["geoHeads"] = geo_head_names
    if entity_names:
        filters["entities"] = entity_names
    if vertical_names:
        filters["verticals"] = vertical_names
    normalized_msps = [
        str(value).strip().upper()
        for value in (msps or [])
        if str(value).strip()
    ]
    if normalized_msps:
        filters["msps"] = normalized_msps
    if financial_year:
        filters["financialYear"] = financial_year
    dataset = _get_active_upload_metadata(filters)
    has_active_upload = bool(dataset.get("uploadId"))

    def _query_rows(active_filters: dict[str, Any]) -> list[dict[str, Any]]:
        where_sql, params = _build_where_clause(active_filters)
        sql = f"""
        select
            r.id,
            r.source_sheet,
            r.source_row_number,
            r.raw_payload,
            r.customer_name,
            r.ms_ps,
            r.resource_name,
            coalesce(
                nullif(trim(r.resource_id), ''),
                nullif(
                    trim(
                        coalesce(
                            r.raw_payload->>'Emp ID',
                            r.raw_payload->>'Resource ID',
                            r.raw_payload->>'Employee ID',
                            r.raw_payload->>'Employee Id'
                        )
                    ),
                    ''
                )
            ) as resource_id,
            r.entity,
            r.gr_entity,
            r.row_us,
            r.strategic_account,
            r.deal_type,
            r.eeennn,
            r.bill_rate,
            r.rate_type,
            r.billed_currency,
            r.forex,
            r.type_of_projects,
            r.start_date,
            r.end_date,
            r.apr_2026,
            r.may_2026,
            r.jun_2026,
            r.jul_2026,
            r.aug_2026,
            r.sep_2026,
            r.oct_2026,
            r.nov_2026,
            r.dec_2026,
            r.jan_2027,
            r.feb_2027,
            r.mar_2027,
            r.fy,
            r.project_name,
            r.client_name,
            r.ocn_number,
            r.practice_head,
            r.{month_key} as budget_value,
            r.bdm,
            r.geo_head,
            r.vertical,
            r.horizontal,
            r.q1,
            r.q2,
            r.q3,
            r.q4,
            f.forecast_value,
            f.billed_hours,
            f.billable_actual_hrs,
            f.submitted_at,
            f.submitted_by_name,
            d.forecast_value as draft_forecast_value,
            d.billed_hours as draft_billed_hours,
            d.billable_actual_hrs as draft_billable_actual_hrs,
            d.updated_at as draft_updated_at,
            d.updated_by_name as draft_updated_by_name,
            r.financial_year
        from rapid_revenue_records r
        join rapid_revenue_uploads u on u.id = r.upload_id
        left join rapid_forecast_entries f
          on f.record_id = r.id and f.forecast_month = %s
        left join rapid_forecast_drafts d
          on d.record_id = r.id
         and d.forecast_month = %s
         and d.draft_owner_role = %s
        where u.is_active = true {where_sql}
        order by
            case
                when upper(coalesce(trim(r.ms_ps), '')) = 'MS' then 0
                when upper(coalesce(trim(r.ms_ps), '')) = 'PS' then 1
                else 2
            end asc,
            r.source_row_number asc,
            r.id asc
    """
        scoped_params = [month_label, month_label, draft_role_id, *params]
        with open_database_connection(require=True) as connection:
            assert connection is not None
            with connection.cursor() as cursor:
                _sanitize_negative_forecast_snapshots(cursor, month_label)
                cursor.execute(sql, scoped_params)
                rows = cursor.fetchall()
            connection.commit()
            return rows

    rows = _query_rows(filters)
    if not rows and effective_bdms and not effective_practice_heads and user_name.strip():
        # Some uploads carry ownership under Practice Head instead of BDM.
        # Fall back for BDM users so they can still see their scoped projects.
        raw_user_name = user_name.strip()
        user_candidates = {raw_user_name}
        if "@" in raw_user_name:
            local = raw_user_name.split("@", 1)[0].strip()
            if local:
                user_candidates.add(local)
                user_candidates.add(local.replace(".", " "))
                user_candidates.add(local.replace(".", " ").title())
                user_candidates.add(local.replace(".", ""))
        fallback_filters = dict(filters)
        fallback_filters.pop("bdms", None)
        fallback_filters["practiceHeads"] = sorted(user_candidates)
        rows = _query_rows(fallback_filters)

    customer_working_days_lookup = _get_customer_working_days_lookup(month_label)
    working_days_lookup = _get_working_days_lookup(month_label)
    serialized_rows = []
    monthly_budget_by_record: dict[int, dict[str, float]] = {}
    submitted_rows = 0
    for row in rows:
        if row.get("forecast_value") is not None:
            submitted_rows += 1
        budget_value = _resolve_month_budget_value(row=row, month_key=month_key)
        submitted_forecast_value = _sanitize_forecast_value_against_budget(
            row.get("forecast_value"),
            budget_value,
        )
        draft_forecast_value = _sanitize_forecast_value_against_budget(
            row.get("draft_forecast_value"),
            budget_value,
        )
        all_month_values = {
            label: _resolve_month_budget_value(row=row, month_key=key)
            for key, label in MONTH_LABEL_BY_KEY.items()
        }
        fy_value = _to_float(row.get("fy"))
        total_month_budget = sum(all_month_values.values())
        if fy_value == 0:
            fy_value = total_month_budget
        budget_value = all_month_values.get(month_label, budget_value)
        monthly_budget_by_record[int(row["id"])] = dict(all_month_values)
        raw_payload = row.get("raw_payload") or {}
        if isinstance(raw_payload, str):
            try:
                raw_payload = json.loads(raw_payload)
            except json.JSONDecodeError:
                raw_payload = {}
        if not isinstance(raw_payload, dict):
            raw_payload = {}
        source_sheet = str(row.get("source_sheet") or "").strip().lower()
        manual_row_type = ""
        if source_sheet.startswith("manual-renewal"):
            manual_row_type = "renewal"
        elif source_sheet.startswith("manual-project"):
            manual_row_type = "new_project"
        country = _normalize_country(str(row.get("row_us") or "Global"))
        customer_scope_key = _build_customer_scope_key(
            customer_name=row.get("customer_name"),
            bdm=row.get("bdm"),
            practice_head=row.get("practice_head"),
            geo_head=row.get("geo_head"),
        )
        working_days = int(
            customer_working_days_lookup.get(
                customer_scope_key,
                working_days_lookup.get(
                    country.lower(),
                    working_days_lookup.get("global", DEFAULT_WORKING_DAYS),
                ),
            )
        )
        serialized_rows.append(
            {
                "recordId": int(row["id"]),
                "Customer Name": str(row.get("customer_name") or ""),
                "MS/PS": str(row.get("ms_ps") or ""),
                "Resource Name": str(row.get("resource_name") or ""),
                "Resource ID": str(row.get("resource_id") or ""),
                "Entity": str(row.get("entity") or ""),
                "GR Entity": str(row.get("gr_entity") or ""),
                "ROW/US": str(row.get("row_us") or ""),
                "Strategic Account": str(row.get("strategic_account") or ""),
                "Deal Type": str(row.get("deal_type") or ""),
                "EEENNN": str(row.get("eeennn") or ""),
                "Bill Rate": _to_float(row.get("bill_rate")),
                "Rate Type": str(row.get("rate_type") or ""),
                "Billed currency": str(row.get("billed_currency") or ""),
                "Forex": _to_float(row.get("forex")),
                "Type of Projects": str(row.get("type_of_projects") or ""),
                "Emp ID": str(row.get("resource_id") or ""),
                "Start Date": _serialize_date(row.get("start_date")),
                "End Date": _serialize_date(row.get("end_date")),
                "Project Name": str(row.get("project_name") or ""),
                "Client Name": str(row.get("client_name") or ""),
                "OCN Number": str(row.get("ocn_number") or ""),
                "Practice Head": str(row.get("practice_head") or ""),
                "Geo Head": str(row.get("geo_head") or ""),
                "Vertical": str(row.get("vertical") or ""),
                "Horizontal": str(row.get("horizontal") or ""),
                "Country": country,
                "Source Row Number": int(row.get("source_row_number") or 0),
                **all_month_values,
                "FY": fy_value,
                month_label: budget_value,
                f"{month_label} Working Days": working_days,
                f"{month_label} Billed Hours": _coerce_non_negative_numeric(row.get("billed_hours")),
                f"{month_label} Billable Actual Hrs": _coerce_non_negative_numeric(row.get("billable_actual_hrs")),
                f"{month_label} Forecast": submitted_forecast_value,
                f"{month_label} Draft Forecast": draft_forecast_value,
                f"{month_label} Draft Billed Hours": _coerce_non_negative_numeric(row.get("draft_billed_hours")),
                f"{month_label} Draft Billable Actual Hrs": _coerce_non_negative_numeric(row.get("draft_billable_actual_hrs")),
                "Q1": _to_float(row.get("q1")),
                "Q2": _to_float(row.get("q2")),
                "Q3": _to_float(row.get("q3")),
                "Q4": _to_float(row.get("q4")),
                "Updated At": _serialize_timestamp(row.get("submitted_at")),
                "Updated By": str(row.get("submitted_by_name") or ""),
                "Submitted At": _serialize_timestamp(row.get("submitted_at")),
                "Submitted By": str(row.get("submitted_by_name") or ""),
                "Draft Updated At": _serialize_timestamp(row.get("draft_updated_at")),
                "Draft Updated By": str(row.get("draft_updated_by_name") or ""),
                "BDM": str(row.get("bdm") or ""),
                "Financial Year": str(row.get("financial_year") or ""),
                "Is Manual Row": source_sheet.startswith("manual-"),
                "Manual Row Type": manual_row_type,
                "Is Reassigned Row": source_sheet.startswith("assignment-")
                or bool(raw_payload.get("Assignment Split")),
            }
        )

    latest_financial_year = (
        str(rows[0].get("financial_year") or "") if rows else dataset.get("financialYear") or financial_year
    )
    bdm_options = sorted(
        {
            str(row.get("bdm") or "").strip()
            for row in rows
            if str(row.get("bdm") or "").strip()
        }
    )
    month_snapshots = (
        _load_forecast_month_snapshots(
            record_ids=[int(row["recordId"]) for row in serialized_rows],
            month_budget_by_record=monthly_budget_by_record,
            draft_role_id=draft_role_id if preview_drafts else "",
        )
        if include_all_months and serialized_rows
        else {}
    )

    return {
        "forecastMonth": month_label,
        "financialYear": latest_financial_year,
        "hasActiveUpload": has_active_upload,
        "bdmOptions": bdm_options,
        "forecastControls": control,
        "rows": serialized_rows,
        "monthSnapshots": month_snapshots if include_all_months else None,
        "summary": {
            "rowCount": len(serialized_rows),
            "submittedRows": submitted_rows,
            "isPastDue": date.today().day > int(control.get("lockoutDay") or FORECAST_CUTOFF_DAY),
            "dueDay": int(control.get("lockoutDay") or FORECAST_CUTOFF_DAY),
            "userId": user_id,
            "userName": user_name,
        },
    }


def _load_forecast_month_snapshots(
    *,
    record_ids: list[int],
    month_budget_by_record: dict[int, dict[str, float]],
    draft_role_id: str,
) -> dict[str, dict[str, dict[str, Any]]]:
    if not record_ids:
        return {}

    archived_entries: dict[tuple[int, str], dict[str, Any]] = {}
    submitted_entries: dict[tuple[int, str], dict[str, Any]] = {}
    draft_entries: dict[tuple[int, str], dict[str, Any]] = {}

    with open_database_connection(require=True) as connection:
        assert connection is not None
        with connection.cursor() as cursor:
            cursor.execute(
                """
                select
                    record_id,
                    forecast_month,
                    forecast_value,
                    billed_hours,
                    billable_actual_hrs,
                    submitted_at,
                    submitted_by_name,
                    archived_at,
                    archived_by
                from rapid_forecast_month_snapshots
                where record_id = any(%s)
                """,
                (record_ids,),
            )
            for row in cursor.fetchall():
                record_id = int(row.get("record_id") or 0)
                month_name = str(row.get("forecast_month") or "").strip()
                if record_id <= 0 or month_name not in MONTH_KEY_BY_LABEL:
                    continue
                archived_entries[(record_id, month_name)] = row

            cursor.execute(
                """
                select
                    record_id,
                    forecast_month,
                    forecast_value,
                    billed_hours,
                    billable_actual_hrs,
                    submitted_at,
                    submitted_by_name
                from rapid_forecast_entries
                where record_id = any(%s)
                """,
                (record_ids,),
            )
            for row in cursor.fetchall():
                record_id = int(row.get("record_id") or 0)
                month_name = str(row.get("forecast_month") or "").strip()
                if record_id <= 0 or month_name not in MONTH_KEY_BY_LABEL:
                    continue
                submitted_entries[(record_id, month_name)] = row

            if draft_role_id:
                cursor.execute(
                    """
                    select
                        record_id,
                        forecast_month,
                        forecast_value,
                        billed_hours,
                        billable_actual_hrs,
                        updated_at,
                        updated_by_name
                    from rapid_forecast_drafts
                    where draft_owner_role = %s
                      and record_id = any(%s)
                    """,
                    (draft_role_id, record_ids),
                )
                for row in cursor.fetchall():
                    record_id = int(row.get("record_id") or 0)
                    month_name = str(row.get("forecast_month") or "").strip()
                    if record_id <= 0 or month_name not in MONTH_KEY_BY_LABEL:
                        continue
                    draft_entries[(record_id, month_name)] = row

    output: dict[str, dict[str, dict[str, Any]]] = {}
    for record_id in record_ids:
        budget_by_month = month_budget_by_record.get(record_id, {})
        per_month: dict[str, dict[str, Any]] = {}
        for month_name in SUPPORTED_FORECAST_MONTHS:
            budget_value = _to_float(budget_by_month.get(month_name))
            submitted = (
                archived_entries.get((record_id, month_name))
                or submitted_entries.get((record_id, month_name), {})
            )
            draft = draft_entries.get((record_id, month_name), {})
            per_month[month_name] = {
                "forecastValue": _sanitize_forecast_value_against_budget(
                    submitted.get("forecast_value"),
                    budget_value,
                ),
                "billedHours": _coerce_non_negative_numeric(submitted.get("billed_hours")),
                "billableActualHrs": _coerce_non_negative_numeric(
                    submitted.get("billable_actual_hrs"),
                ),
                "submittedAt": _serialize_timestamp(submitted.get("submitted_at")),
                "submittedBy": str(submitted.get("submitted_by_name") or ""),
                "archivedAt": _serialize_timestamp(submitted.get("archived_at")),
                "archivedBy": str(submitted.get("archived_by") or ""),
                "draftForecastValue": _sanitize_forecast_value_against_budget(
                    draft.get("forecast_value"),
                    budget_value,
                ),
                "draftBilledHours": _coerce_non_negative_numeric(draft.get("billed_hours")),
                "draftBillableActualHrs": _coerce_non_negative_numeric(
                    draft.get("billable_actual_hrs"),
                ),
                "draftUpdatedAt": _serialize_timestamp(draft.get("updated_at")),
                "draftUpdatedBy": str(draft.get("updated_by_name") or ""),
            }
        output[str(record_id)] = per_month

    return output


def save_bdm_forecast_draft(
    user_id: str,
    user_name: str,
    bdm_names: list[str],
    forecast_month: str,
    rows: list[dict[str, Any]],
    submitter_role_id: str | None = None,
) -> dict[str, Any]:
    ensure_postgres_schema()
    month_key = MONTH_KEY_BY_LABEL.get(forecast_month)
    if not month_key:
        raise HTTPException(status_code=400, detail="Choose a supported forecast month.")
    control = get_forecast_control_settings()
    role_id = _resolve_submitter_role_id(submitter_role_id)
    lockin_day = int(control.get("lockinDay") or DEFAULT_LOCKIN_DAY)
    lockout_day = int(control.get("lockoutDay") or DEFAULT_LOCKOUT_DAY)
    lockin_date = _coerce_date_input(control.get("lockinDate"))
    lockout_date = _coerce_date_input(control.get("lockoutDate"))
    active_month = str(control.get("activeMonth") or control.get("rolloutStartMonth") or DEFAULT_ROLLOUT_START_MONTH)
    locked_months = set(control.get("lockedMonths") or _resolve_locked_months(active_month))
    if forecast_month in locked_months:
        raise HTTPException(
            status_code=403,
            detail=f"{forecast_month} is locked. Update months from {active_month} onward.",
        )
    editable_months = set(control.get("editableMonths") or _resolve_editable_months(active_month, window_open=True))
    if forecast_month not in editable_months:
        raise HTTPException(
            status_code=403,
            detail=f"{forecast_month} is not open for forecast updates. Update months from {active_month} onward.",
        )

    normalized_bdm_scope = {
        str(value).strip().lower()
        for value in bdm_names
        if str(value).strip()
    }

    row_map: dict[int, dict[str, Any]] = {}
    for row in rows:
        try:
            record_id = int(row.get("recordId"))
        except Exception as error:  # pragma: no cover
            raise HTTPException(status_code=400, detail="Each forecast row must include a recordId.") from error
        row_map[record_id] = {
            "hasForecastValue": "forecastValue" in row,
            "forecastValue": row.get("forecastValue"),
            "hasBilledHours": "billedHours" in row,
            "billedHours": row.get("billedHours"),
            "hasBillableActualHrs": "billableActualHrs" in row,
            "billableActualHrs": row.get("billableActualHrs"),
            "rowValues": row.get("rowValues") if isinstance(row.get("rowValues"), dict) else {},
        }

    if not row_map:
        raise HTTPException(status_code=400, detail="No forecast rows were provided.")

    now_iso = utc_now_iso()
    with open_database_connection(require=True) as connection:
        assert connection is not None
        with connection.cursor() as cursor:
            cursor.execute(
                """
                select
                    id,
                    bdm,
                    financial_year,
                    upload_id,
                    coalesce({month_key}, 0) as budget_value,
                    coalesce(nullif(trim(billed_currency), ''), 'USD') as billed_currency,
                    coalesce(forex, 0) as forex
                from rapid_revenue_records
                where id = any(%s)
                """.format(month_key=month_key),
                (list(row_map.keys()),),
            )
            db_rows = cursor.fetchall()
            db_row_by_id = {
                int(row.get("id")): row
                for row in db_rows
            }

            missing_ids = sorted(set(row_map.keys()) - set(db_row_by_id.keys()))
            if missing_ids:
                raise HTTPException(
                    status_code=404,
                    detail=f"One or more forecast rows do not exist: {', '.join(str(value) for value in missing_ids[:10])}.",
                )

            cursor.execute(
                """
                select
                    record_id,
                    forecast_value,
                    billed_hours,
                    billable_actual_hrs
                from rapid_forecast_drafts
                where forecast_month = %s
                  and draft_owner_role = %s
                  and record_id = any(%s)
                """,
                (forecast_month, role_id, list(row_map.keys())),
            )
            existing_drafts = {
                int(row.get("record_id")): row
                for row in cursor.fetchall()
            }

            for db_row in db_rows:
                scoped_bdm = str(db_row.get("bdm") or "").strip().lower()
                if normalized_bdm_scope and scoped_bdm not in normalized_bdm_scope:
                    raise HTTPException(status_code=403, detail="One or more forecast rows are outside the signed-in BDM scope.")

            for db_row in db_rows:
                record_id = int(db_row["id"])
                row_payload = row_map[record_id]
                existing = existing_drafts.get(record_id, {})
                row_values = row_payload.get("rowValues") or {}

                update_fields: list[str] = []
                update_params: list[Any] = []
                numeric_map = {
                    "billRate": "bill_rate",
                    "forex": "forex",
                    "fy": "fy",
                    "q1": "q1",
                    "q2": "q2",
                    "q3": "q3",
                    "q4": "q4",
                }
                text_map = {
                    "customerName": "customer_name",
                    "msps": "ms_ps",
                    "entity": "entity",
                    "grEntity": "gr_entity",
                    "rowUs": "row_us",
                    "strategicAccount": "strategic_account",
                    "resourceId": "resource_id",
                    "resourceName": "resource_name",
                    "dealType": "deal_type",
                    "eeennn": "eeennn",
                    "rateType": "rate_type",
                    "billedCurrency": "billed_currency",
                    "typeOfProjects": "type_of_projects",
                    "projectName": "project_name",
                    "ocnNumber": "ocn_number",
                    "practiceHead": "practice_head",
                    "bdm": "bdm",
                    "geoHead": "geo_head",
                    "vertical": "vertical",
                    "horizontal": "horizontal",
                    "clientName": "client_name",
                }
                date_map = {
                    "startDate": "start_date",
                    "endDate": "end_date",
                }

                for payload_key, column in numeric_map.items():
                    if payload_key not in row_values:
                        continue
                    update_fields.append(f"{column} = %s")
                    update_params.append(_to_decimal(_parse_optional_numeric(row_values.get(payload_key))))
                for payload_key, column in text_map.items():
                    if payload_key not in row_values:
                        continue
                    update_fields.append(f"{column} = %s")
                    update_params.append(str(row_values.get(payload_key) or "").strip())
                for payload_key, column in date_map.items():
                    if payload_key not in row_values:
                        continue
                    update_fields.append(f"{column} = %s")
                    update_params.append(_coerce_date_input(row_values.get(payload_key)))

                if update_fields:
                    cursor.execute(
                        f"""
                        update rapid_revenue_records
                        set {", ".join(update_fields)}
                        where id = %s
                        """,
                        (*update_params, record_id),
                    )

                if (
                    not row_payload.get("hasForecastValue")
                    and not row_payload.get("hasBilledHours")
                    and not row_payload.get("hasBillableActualHrs")
                    and not existing
                ):
                    continue

                forecast_value = _resolve_submission_numeric_value(
                    has_value=bool(row_payload.get("hasForecastValue")),
                    payload_value=row_payload.get("forecastValue"),
                    existing_value=existing.get("forecast_value"),
                )
                budget_value = _convert_local_budget_to_usd(
                    db_row.get("budget_value"),
                    db_row.get("billed_currency"),
                    db_row.get("forex"),
                )
                forecast_value = _sanitize_forecast_value_against_budget(
                    forecast_value,
                    budget_value,
                )
                billed_hours = _coerce_non_negative_numeric(
                    _resolve_submission_numeric_value(
                        has_value=bool(row_payload.get("hasBilledHours")),
                        payload_value=row_payload.get("billedHours"),
                        existing_value=existing.get("billed_hours"),
                    )
                )
                billable_actual_hrs = _coerce_non_negative_numeric(
                    _resolve_submission_numeric_value(
                        has_value=bool(row_payload.get("hasBillableActualHrs")),
                        payload_value=row_payload.get("billableActualHrs"),
                        existing_value=existing.get("billable_actual_hrs"),
                    )
                )
                cursor.execute(
                    """
                    insert into rapid_forecast_drafts (
                        id,
                        record_id,
                        forecast_month,
                        draft_owner_role,
                        forecast_value,
                        billed_hours,
                        billable_actual_hrs,
                        updated_by_user_id,
                        updated_by_name,
                        updated_at
                    )
                    values (%s, %s, %s, %s, %s, %s, %s, %s, %s, %s::timestamptz)
                    on conflict (record_id, forecast_month, draft_owner_role)
                    do update set
                        forecast_value = excluded.forecast_value,
                        billed_hours = excluded.billed_hours,
                        billable_actual_hrs = excluded.billable_actual_hrs,
                        updated_by_user_id = excluded.updated_by_user_id,
                        updated_by_name = excluded.updated_by_name,
                        updated_at = excluded.updated_at
                    """,
                    (
                        str(uuid4()),
                        db_row.get("id"),
                        forecast_month,
                        role_id,
                        _to_decimal(forecast_value),
                        _to_decimal(billed_hours),
                        _to_decimal(billable_actual_hrs),
                        user_id,
                        user_name,
                        now_iso,
                    ),
                )
        connection.commit()

    return {
        "status": "draft_saved",
        "savedRows": len(row_map),
        "forecastMonth": forecast_month,
        "savedAt": now_iso,
    }


def save_bdm_forecast_submission(
    user_id: str,
    user_name: str,
    bdm_names: list[str],
    forecast_month: str,
    rows: list[dict[str, Any]],
    submitter_role_id: str | None = None,
) -> dict[str, Any]:
    ensure_postgres_schema()
    month_key = MONTH_KEY_BY_LABEL.get(forecast_month)
    if not month_key:
        raise HTTPException(status_code=400, detail="Choose a supported forecast month.")
    control = get_forecast_control_settings()
    role_id = _resolve_submitter_role_id(submitter_role_id)
    lockin_day = int(control.get("lockinDay") or DEFAULT_LOCKIN_DAY)
    lockout_day = int(control.get("lockoutDay") or DEFAULT_LOCKOUT_DAY)
    lockin_date = _coerce_date_input(control.get("lockinDate"))
    lockout_date = _coerce_date_input(control.get("lockoutDate"))
    active_month = str(control.get("activeMonth") or control.get("rolloutStartMonth") or DEFAULT_ROLLOUT_START_MONTH)
    locked_months = set(control.get("lockedMonths") or _resolve_locked_months(active_month))
    if forecast_month in locked_months:
        raise HTTPException(
            status_code=403,
            detail=f"{forecast_month} is locked. Update months from {active_month} onward.",
        )
    editable_months = set(control.get("editableMonths") or _resolve_editable_months(active_month, window_open=True))
    if forecast_month not in editable_months:
        raise HTTPException(
            status_code=403,
            detail=f"{forecast_month} is not open for forecast updates. Update months from {active_month} onward.",
        )

    normalized_bdm_scope = {
        str(value).strip().lower()
        for value in bdm_names
        if str(value).strip()
    }

    row_map: dict[int, dict[str, Any]] = {}
    for row in rows:
        try:
            record_id = int(row.get("recordId"))
        except Exception as error:  # pragma: no cover
            raise HTTPException(status_code=400, detail="Each forecast row must include a recordId.") from error
        row_map[record_id] = {
            "hasForecastValue": "forecastValue" in row,
            "forecastValue": row.get("forecastValue"),
            "hasBilledHours": "billedHours" in row,
            "billedHours": row.get("billedHours"),
            "hasBillableActualHrs": "billableActualHrs" in row,
            "billableActualHrs": row.get("billableActualHrs"),
            "rowValues": row.get("rowValues") if isinstance(row.get("rowValues"), dict) else {},
        }

    if not row_map:
        raise HTTPException(status_code=400, detail="No forecast rows were provided.")

    now_iso = utc_now_iso()
    with open_database_connection(require=True) as connection:
        assert connection is not None
        with connection.cursor() as cursor:
            cursor.execute(
                """
                select
                    id,
                    bdm,
                    financial_year,
                    upload_id,
                    coalesce({month_key}, 0) as budget_value,
                    coalesce(nullif(trim(billed_currency), ''), 'USD') as billed_currency,
                    coalesce(forex, 0) as forex
                from rapid_revenue_records
                where id = any(%s)
                """.format(month_key=month_key),
                (list(row_map.keys()),),
            )
            db_rows = cursor.fetchall()
            db_row_by_id = {
                int(row.get("id")): row
                for row in db_rows
            }

            missing_ids = sorted(set(row_map.keys()) - set(db_row_by_id.keys()))
            if missing_ids:
                raise HTTPException(
                    status_code=404,
                    detail=f"One or more forecast rows do not exist: {', '.join(str(value) for value in missing_ids[:10])}.",
                )

            cursor.execute(
                """
                select
                    record_id,
                    forecast_value,
                    billed_hours,
                    billable_actual_hrs
                from rapid_forecast_entries
                where forecast_month = %s and record_id = any(%s)
                """,
                (forecast_month, list(row_map.keys())),
            )
            existing_entries = {
                int(row.get("record_id")): row
                for row in cursor.fetchall()
            }

            for db_row in db_rows:
                scoped_bdm = str(db_row.get("bdm") or "").strip().lower()
                if normalized_bdm_scope and scoped_bdm not in normalized_bdm_scope:
                    raise HTTPException(status_code=403, detail="One or more forecast rows are outside the signed-in BDM scope.")

            for db_row in db_rows:
                record_id = int(db_row["id"])
                row_payload = row_map[record_id]
                existing = existing_entries.get(record_id, {})
                row_values = row_payload.get("rowValues") or {}

                update_fields: list[str] = []
                update_params: list[Any] = []
                numeric_map = {
                    "billRate": "bill_rate",
                    "forex": "forex",
                    "fy": "fy",
                    "q1": "q1",
                    "q2": "q2",
                    "q3": "q3",
                    "q4": "q4",
                }
                text_map = {
                    "customerName": "customer_name",
                    "msps": "ms_ps",
                    "entity": "entity",
                    "grEntity": "gr_entity",
                    "rowUs": "row_us",
                    "strategicAccount": "strategic_account",
                    "resourceId": "resource_id",
                    "resourceName": "resource_name",
                    "dealType": "deal_type",
                    "eeennn": "eeennn",
                    "rateType": "rate_type",
                    "billedCurrency": "billed_currency",
                    "typeOfProjects": "type_of_projects",
                    "projectName": "project_name",
                    "ocnNumber": "ocn_number",
                    "practiceHead": "practice_head",
                    "bdm": "bdm",
                    "geoHead": "geo_head",
                    "vertical": "vertical",
                    "horizontal": "horizontal",
                    "clientName": "client_name",
                }
                date_map = {
                    "startDate": "start_date",
                    "endDate": "end_date",
                }

                for payload_key, column in numeric_map.items():
                    if payload_key not in row_values:
                        continue
                    update_fields.append(f"{column} = %s")
                    update_params.append(_to_decimal(_parse_optional_numeric(row_values.get(payload_key))))
                for payload_key, column in text_map.items():
                    if payload_key not in row_values:
                        continue
                    update_fields.append(f"{column} = %s")
                    update_params.append(str(row_values.get(payload_key) or "").strip())
                for payload_key, column in date_map.items():
                    if payload_key not in row_values:
                        continue
                    update_fields.append(f"{column} = %s")
                    update_params.append(_coerce_date_input(row_values.get(payload_key)))

                if update_fields:
                    cursor.execute(
                        f"""
                        update rapid_revenue_records
                        set {", ".join(update_fields)}
                        where id = %s
                        """,
                        (*update_params, record_id),
                    )
                forecast_value = _resolve_submission_numeric_value(
                    has_value=bool(row_payload.get("hasForecastValue")),
                    payload_value=row_payload.get("forecastValue"),
                    existing_value=existing.get("forecast_value"),
                )
                budget_value = _convert_local_budget_to_usd(
                    db_row.get("budget_value"),
                    db_row.get("billed_currency"),
                    db_row.get("forex"),
                )
                forecast_value = _sanitize_forecast_value_against_budget(
                    forecast_value,
                    budget_value,
                )
                billed_hours = _coerce_non_negative_numeric(
                    _resolve_submission_numeric_value(
                        has_value=bool(row_payload.get("hasBilledHours")),
                        payload_value=row_payload.get("billedHours"),
                        existing_value=existing.get("billed_hours"),
                    )
                )
                billable_actual_hrs = _coerce_non_negative_numeric(
                    _resolve_submission_numeric_value(
                        has_value=bool(row_payload.get("hasBillableActualHrs")),
                        payload_value=row_payload.get("billableActualHrs"),
                        existing_value=existing.get("billable_actual_hrs"),
                    )
                )
                cursor.execute(
                    """
                    insert into rapid_forecast_entries (
                        id,
                        upload_id,
                        record_id,
                        financial_year,
                        forecast_month,
                        budget_value,
                        forecast_value,
                        billed_hours,
                        billable_actual_hrs,
                        submitted_by_user_id,
                        submitted_by_name,
                        submitted_at
                    )
                    values (%s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s::timestamptz)
                    on conflict (record_id, forecast_month)
                    do update set
                        budget_value = excluded.budget_value,
                        forecast_value = excluded.forecast_value,
                        billed_hours = excluded.billed_hours,
                        billable_actual_hrs = excluded.billable_actual_hrs,
                        submitted_by_user_id = excluded.submitted_by_user_id,
                        submitted_by_name = excluded.submitted_by_name,
                        submitted_at = excluded.submitted_at
                    """,
                    (
                        str(uuid4()),
                        db_row.get("upload_id"),
                        db_row.get("id"),
                        db_row.get("financial_year"),
                        forecast_month,
                        _to_decimal(db_row.get("budget_value")),
                        _to_decimal(forecast_value),
                        _to_decimal(billed_hours),
                        _to_decimal(billable_actual_hrs),
                        user_id,
                        user_name,
                        now_iso,
                    ),
                )
                if role_id in ROLE_SUBMISSION_IDS:
                    cursor.execute(
                        """
                        insert into rapid_forecast_role_entries (
                            id,
                            record_id,
                            forecast_month,
                            submitter_role,
                            forecast_value,
                            billed_hours,
                            billable_actual_hrs,
                            submitted_by_user_id,
                            submitted_by_name,
                            submitted_at
                        )
                        values (%s, %s, %s, %s, %s, %s, %s, %s, %s, %s::timestamptz)
                        on conflict (record_id, forecast_month, submitter_role)
                        do update set
                            forecast_value = excluded.forecast_value,
                            billed_hours = excluded.billed_hours,
                            billable_actual_hrs = excluded.billable_actual_hrs,
                            submitted_by_user_id = excluded.submitted_by_user_id,
                            submitted_by_name = excluded.submitted_by_name,
                            submitted_at = excluded.submitted_at
                        """,
                        (
                            str(uuid4()),
                            db_row.get("id"),
                            forecast_month,
                            role_id,
                            _to_decimal(forecast_value),
                            _to_decimal(billed_hours),
                            _to_decimal(billable_actual_hrs),
                            user_id,
                            user_name,
                            now_iso,
                        ),
                    )

            mismatch_record_ids: list[int] = []
            if row_map:
                cursor.execute(
                    """
                    select bdm.record_id
                    from rapid_forecast_role_entries bdm
                    join rapid_forecast_role_entries ph
                      on ph.record_id = bdm.record_id
                     and ph.forecast_month = bdm.forecast_month
                     and ph.submitter_role = 'practice-head'
                    where bdm.submitter_role = 'bdm'
                      and bdm.forecast_month = %s
                      and bdm.record_id = any(%s)
                      and (
                        abs(coalesce(bdm.forecast_value, 0) - coalesce(ph.forecast_value, 0)) > 0.009
                        or abs(coalesce(bdm.billed_hours, 0) - coalesce(ph.billed_hours, 0)) > 0.009
                        or abs(coalesce(bdm.billable_actual_hrs, 0) - coalesce(ph.billable_actual_hrs, 0)) > 0.009
                      )
                    order by bdm.record_id asc
                    """,
                    (forecast_month, list(row_map.keys())),
                )
                mismatch_record_ids = [int(row.get("record_id")) for row in cursor.fetchall()]

            cursor.execute(
                """
                delete from rapid_forecast_drafts
                where forecast_month = %s
                  and draft_owner_role = %s
                  and record_id = any(%s)
                """,
                (forecast_month, role_id, list(row_map.keys())),
            )

            cursor.execute(
                """
                insert into rapid_notifications (
                    id,
                    category,
                    audience_role,
                    audience_user_id,
                    title,
                    message,
                    link,
                    created_at,
                    metadata
                )
                values (%s, %s, %s, %s, %s, %s, %s, %s::timestamptz, %s::jsonb)
                """,
                (
                    str(uuid4()),
                    "forecast_submitted",
                    "executive",
                    None,
                    f"{user_name} submitted {forecast_month} forecast",
                    f"{user_name} updated {len(db_rows)} forecast rows for {forecast_month}.",
                    "/notifications",
                    now_iso,
                    json.dumps(
                        {
                            "forecastMonth": forecast_month,
                            "bdm": bdm_names,
                            "submitterRole": role_id,
                            "mismatchRecordIds": mismatch_record_ids,
                        }
                    ),
                ),
            )
        connection.commit()

    return {
        "status": "saved",
        "savedRows": len(row_map),
        "forecastMonth": forecast_month,
        "submittedAt": now_iso,
        "mismatchRecordIds": mismatch_record_ids,
        "mismatchCount": len(mismatch_record_ids),
    }


def create_renewal_forecast_row(
