    return {
        "status": "cleared",
        "deletedPrimaryRows": primary_count,
        "deletedRoleRows": role_count,
        "requestedBy": user_name,
        "requestedByUserId": user_id,
        "clearedAt": utc_now_iso(),
    }


def reassign_project_scope(
    *,
    user_id: str,
    user_name: str,
    assignment_type: str,
    effective_month: str,
    record_id: int | None = None,
    current_bdm: str | None = None,
    next_bdm: str | None = None,
    current_geo_head: str | None = None,
    next_geo_head: str | None = None,
    practice_head: str | None = None,
    entity: str | None = None,
    financial_year: str | None = None,
) -> dict[str, Any]:
    ensure_postgres_schema()
    ensure_budget_sync_to_rapid_revenue(financial_year)

    normalized_type = str(assignment_type or "").strip().lower().replace("-", "_")
    if normalized_type not in {"bdm", "geo_head"}:
        raise HTTPException(status_code=400, detail="Choose BDM or Geo Head reassignment.")
    if effective_month not in MONTH_KEY_BY_LABEL:
        raise HTTPException(status_code=400, detail="Choose a supported effective month.")

    target_bdm = str(next_bdm or "").strip()
    target_geo_head = str(next_geo_head or "").strip()
    if normalized_type == "bdm" and not target_bdm:
        raise HTTPException(status_code=400, detail="Choose the new BDM.")
    if normalized_type == "geo_head" and not target_geo_head:
        raise HTTPException(status_code=400, detail="Choose the new Geo Head.")

    effective_index = list(SUPPORTED_FORECAST_MONTHS).index(effective_month)
    future_months = list(SUPPORTED_FORECAST_MONTHS[effective_index:])
    future_month_keys = [MONTH_KEY_BY_LABEL[month] for month in future_months]
    now_iso = utc_now_iso()

    where_clauses = ["u.is_active = true"]
    params: list[Any] = []
    if record_id:
        where_clauses.append("r.id = %s")
        params.append(record_id)
    if financial_year:
        where_clauses.append("r.financial_year = %s")
        params.append(str(financial_year).strip())
    if normalized_type == "bdm" and current_bdm:
        where_clauses.append("lower(trim(coalesce(r.bdm, ''))) = %s")
        params.append(str(current_bdm).strip().lower())
    if normalized_type == "geo_head":
        if not current_geo_head:
            raise HTTPException(status_code=400, detail="Choose the Geo Head who is leaving.")
        where_clauses.append("lower(trim(coalesce(r.geo_head, ''))) = %s")
        params.append(str(current_geo_head).strip().lower())
        if current_bdm:
            where_clauses.append("lower(trim(coalesce(r.bdm, ''))) = %s")
            params.append(str(current_bdm).strip().lower())
    if practice_head:
        where_clauses.append("lower(trim(coalesce(r.practice_head, ''))) = %s")
        params.append(str(practice_head).strip().lower())
    if entity:
        where_clauses.append("lower(trim(coalesce(r.entity, ''))) = %s")
        params.append(str(entity).strip().lower())

    if not record_id and normalized_type == "bdm" and not current_bdm:
        raise HTTPException(status_code=400, detail="Choose a project or the BDM who is leaving.")

    with open_database_connection(require=True) as connection:
        assert connection is not None
        created_record_ids: list[int] = []
        affected_record_ids: list[int] = []
        reverted_record_ids: list[int] = []
        with connection.cursor() as cursor:
            cursor.execute(
                f"""
                select r.*
                from rapid_revenue_records r
                join rapid_revenue_uploads u on u.id = r.upload_id
                where {" and ".join(where_clauses)}
                order by r.source_row_number asc, r.id asc
                """,
                params,
            )
            source_rows = cursor.fetchall()

            if not source_rows:
                raise HTTPException(status_code=404, detail="No active project rows matched the reassignment scope.")

            insert_columns = [
                "upload_id",
                "financial_year",
                "source_sheet",
                "source_row_number",
                "raw_payload",
                *RAPID_REVENUE_COLUMN_KEYS,
            ]
            update_month_columns = [
                *MONTH_KEY_BY_LABEL.values(),
                "q1",
                "q2",
                "q3",
                "q4",
                "fy",
                "raw_payload",
            ]

            for source_row in source_rows:
                source_record_id = int(source_row.get("id") or 0)
                source_values = {
                    field.key: source_row.get(field.key)
                    for field in RAPID_REVENUE_FIELD_SPECS
                }
                current_value = (
                    str(source_values.get("bdm") or "").strip()
                    if normalized_type == "bdm"
                    else str(source_values.get("geo_head") or "").strip()
                )
                target_value = target_bdm if normalized_type == "bdm" else target_geo_head
                if current_value.lower() == target_value.lower():
                    continue
                if normalized_type == "geo_head" and _is_geo_head_revert_to_original(
                    source_row.get("raw_payload"),
                    current_geo_head=current_value,
                    target_geo_head=target_geo_head,
                ):
                    restored_record_id, removed_record_id = _restore_geo_head_reassignment(
                        cursor=cursor,
                        source_row=source_row,
                        source_values=source_values,
                        future_months=future_months,
                        future_month_keys=future_month_keys,
                        update_month_columns=update_month_columns,
                    )
                    reverted_record_ids.extend([restored_record_id, removed_record_id])
                    affected_record_ids.extend([restored_record_id, removed_record_id])
                    continue

                old_values, new_values = _split_reassignment_values(
                    source_values,
                    future_month_keys=future_month_keys,
                )
                if normalized_type == "bdm":
                    new_values["bdm"] = target_bdm
                else:
                    new_values["geo_head"] = target_geo_head

                metadata = {
                    "type": normalized_type,
                    "sourceRecordId": source_record_id,
                    "from": current_value,
                    "to": target_value,
                    "effectiveMonth": effective_month,
                    "futureMonths": future_months,
                    "scopeBdm": current_bdm,
                    "scopePracticeHead": practice_head,
                    "scopeEntity": entity,
                    "createdByUserId": user_id,
                    "createdBy": user_name,
                    "createdAt": now_iso,
                }
                new_raw_payload = _merge_assignment_metadata(
                    _build_raw_payload_from_values(new_values),
                    {**metadata, "direction": "incoming"},
                )
                old_raw_payload = _merge_assignment_metadata(
                    source_row.get("raw_payload"),
                    {**metadata, "direction": "outgoing"},
                )
                source_sheet = f"assignment-{normalized_type}"
                source_row_number = _next_manual_source_row_number(
                    cursor=cursor,
                    upload_id=source_row.get("upload_id"),
                    source_sheet=source_sheet,
                )
                cursor.execute(
                    f"""
                    insert into rapid_revenue_records ({", ".join(insert_columns)})
                    values ({", ".join(["%s", "%s", "%s", "%s", "%s::jsonb", *["%s"] * len(RAPID_REVENUE_COLUMN_KEYS)])})
                    returning id
                    """,
                    (
                        source_row.get("upload_id"),
                        source_row.get("financial_year"),
                        source_sheet,
                        source_row_number,
                        json.dumps(new_raw_payload),
                        *[new_values.get(column_key) for column_key in RAPID_REVENUE_COLUMN_KEYS],
                    ),
                )
                created_row = cursor.fetchone() or {}
                created_record_id = int(created_row.get("id") or 0)
                if created_record_id <= 0:
                    raise HTTPException(status_code=500, detail="Unable to create reassigned project row.")

                cursor.execute(
                    f"""
                    update rapid_revenue_records
                    set {", ".join([f"{column} = %s" for column in update_month_columns[:-1]])},
                        raw_payload = %s::jsonb
                    where id = %s
                    """,
                    (
                        *[old_values.get(column) for column in update_month_columns[:-1]],
                        json.dumps(old_raw_payload),
                        source_record_id,
                    ),
                )

                cursor.execute(
                    """
                    select
                        upload_id,
                        financial_year,
                        forecast_month,
                        budget_value,
                        forecast_value,
                        billed_hours,
                        billable_actual_hrs,
                        submitted_by_user_id,
                        submitted_by_name,
                        submitted_at
                    from rapid_forecast_entries
                    where record_id = %s and forecast_month = any(%s)
                    """,
                    (source_record_id, future_months),
                )
                moved_entries = cursor.fetchall()
                if moved_entries:
                    cursor.executemany(
                        """
                        insert into rapid_forecast_entries (
                            id,
                            upload_id,
                            record_id,
                            financial_year,
                            forecast_month,
                            budget_value,
                            forecast_value,
                            billed_hours,
                            billable_actual_hrs,
                            submitted_by_user_id,
                            submitted_by_name,
                            submitted_at
                        )
                        values (%s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s)
                        on conflict (record_id, forecast_month)
                        do update set
                            budget_value = excluded.budget_value,
                            forecast_value = excluded.forecast_value,
                            billed_hours = excluded.billed_hours,
                            billable_actual_hrs = excluded.billable_actual_hrs,
                            submitted_by_user_id = excluded.submitted_by_user_id,
                            submitted_by_name = excluded.submitted_by_name,
                            submitted_at = excluded.submitted_at
                        """,
                        [
                            (
                                str(uuid4()),
                                row.get("upload_id"),
                                created_record_id,
                                row.get("financial_year"),
                                row.get("forecast_month"),
                                row.get("budget_value"),
                                row.get("forecast_value"),
                                row.get("billed_hours"),
                                row.get("billable_actual_hrs"),
                                row.get("submitted_by_user_id"),
                                row.get("submitted_by_name"),
                                row.get("submitted_at"),
                            )
                            for row in moved_entries
                        ],
                    )

                cursor.execute(
                    """
                    select
                        forecast_month,
                        submitter_role,
                        forecast_value,
                        billed_hours,
                        billable_actual_hrs,
                        submitted_by_user_id,
                        submitted_by_name,
                        submitted_at
                    from rapid_forecast_role_entries
                    where record_id = %s and forecast_month = any(%s)
                    """,
                    (source_record_id, future_months),
                )
                moved_role_entries = cursor.fetchall()
                if moved_role_entries:
                    cursor.executemany(
                        """
                        insert into rapid_forecast_role_entries (
                            id,
                            record_id,
                            forecast_month,
                            submitter_role,
                            forecast_value,
                            billed_hours,
                            billable_actual_hrs,
                            submitted_by_user_id,
                            submitted_by_name,
                            submitted_at
                        )
                        values (%s, %s, %s, %s, %s, %s, %s, %s, %s, %s)
                        on conflict (record_id, forecast_month, submitter_role)
                        do update set
                            forecast_value = excluded.forecast_value,
                            billed_hours = excluded.billed_hours,
                            billable_actual_hrs = excluded.billable_actual_hrs,
                            submitted_by_user_id = excluded.submitted_by_user_id,
                            submitted_by_name = excluded.submitted_by_name,
                            submitted_at = excluded.submitted_at
                        """,
                        [
                            (
                                str(uuid4()),
                                created_record_id,
                                row.get("forecast_month"),
                                row.get("submitter_role"),
                                row.get("forecast_value"),
                                row.get("billed_hours"),
                                row.get("billable_actual_hrs"),
                                row.get("submitted_by_user_id"),
                                row.get("submitted_by_name"),
                                row.get("submitted_at"),
                            )
                            for row in moved_role_entries
                        ],
                    )

                cursor.execute(
                    """
                    select
                        forecast_month,
                        draft_owner_role,
                        forecast_value,
                        billed_hours,
                        billable_actual_hrs,
                        updated_by_user_id,
                        updated_by_name,
                        updated_at
                    from rapid_forecast_drafts
                    where record_id = %s and forecast_month = any(%s)
                    """,
                    (source_record_id, future_months),
                )
                moved_drafts = cursor.fetchall()
                if moved_drafts:
                    cursor.executemany(
                        """
                        insert into rapid_forecast_drafts (
                            id,
                            record_id,
                            forecast_month,
                            draft_owner_role,
                            forecast_value,
                            billed_hours,
                            billable_actual_hrs,
                            updated_by_user_id,
                            updated_by_name,
                            updated_at
                        )
                        values (%s, %s, %s, %s, %s, %s, %s, %s, %s, %s)
                        on conflict (record_id, forecast_month, draft_owner_role)
                        do update set
                            forecast_value = excluded.forecast_value,
                            billed_hours = excluded.billed_hours,
                            billable_actual_hrs = excluded.billable_actual_hrs,
                            updated_by_user_id = excluded.updated_by_user_id,
                            updated_by_name = excluded.updated_by_name,
                            updated_at = excluded.updated_at
                        """,
                        [
                            (
                                str(uuid4()),
                                created_record_id,
                                row.get("forecast_month"),
                                row.get("draft_owner_role"),
                                row.get("forecast_value"),
                                row.get("billed_hours"),
                                row.get("billable_actual_hrs"),
                                row.get("updated_by_user_id"),
                                row.get("updated_by_name"),
                                row.get("updated_at"),
                            )
                            for row in moved_drafts
                        ],
                    )
                cursor.execute(
                    "delete from rapid_forecast_entries where record_id = %s and forecast_month = any(%s)",
                    (source_record_id, future_months),
                )
                cursor.execute(
                    "delete from rapid_forecast_role_entries where record_id = %s and forecast_month = any(%s)",
                    (source_record_id, future_months),
                )
                cursor.execute(
                    "delete from rapid_forecast_drafts where record_id = %s and forecast_month = any(%s)",
                    (source_record_id, future_months),
                )

                created_record_ids.append(created_record_id)
                affected_record_ids.append(source_record_id)

            if not created_record_ids and reverted_record_ids:
                return {
                    "status": "reverted",
                    "assignmentType": normalized_type,
                    "effectiveMonth": effective_month,
                    "affectedRecords": len(reverted_record_ids),
                    "createdRecords": 0,
                    "affectedRecordIds": reverted_record_ids,
                    "createdRecordIds": [],
                    "message": (
                        f"{max(len(reverted_record_ids) // 2, 1)} moved row(s) returned to "
                        f"{target_geo_head} from {effective_month}."
                    ),
                }

            if not created_record_ids:
                raise HTTPException(status_code=400, detail="All matched rows are already assigned to the selected owner.")

            cursor.execute(
                """
                insert into rapid_notifications (
                    id,
                    category,
                    audience_role,
                    audience_user_id,
                    title,
                    message,
                    link,
                    created_at,
                    metadata
                )
                values (%s, %s, %s, %s, %s, %s, %s, %s::timestamptz, %s::jsonb)
                """,
                (
                    str(uuid4()),
                    "project_reassignment_applied",
                    "executive",
                    None,
                    f"{user_name} applied project reassignment",
                    (
                        f"{len(created_record_ids)} project row(s) moved to "
                        f"{target_bdm or target_geo_head} from {effective_month}."
                    ),
                    "/executive/forecast",
                    now_iso,
                    json.dumps(
                        {
                            "assignmentType": normalized_type,
                            "effectiveMonth": effective_month,
                            "createdRecordIds": created_record_ids,
                            "affectedRecordIds": affected_record_ids,
                            "targetBdm": target_bdm,
                            "targetGeoHead": target_geo_head,
                            "practiceHead": practice_head,
                            "entity": entity,
                        }
                    ),
                ),
            )
        connection.commit()

    return {
        "status": "reassigned",
        "assignmentType": normalized_type,
        "effectiveMonth": effective_month,
        "affectedRecords": len(affected_record_ids),
        "createdRecords": len(created_record_ids),
        "affectedRecordIds": affected_record_ids,
        "createdRecordIds": created_record_ids,
    }


def get_project_assignment_requests(
    *,
    geo_head_names: list[str] | None = None,
    status: str | None = None,
) -> dict[str, Any]:
    ensure_postgres_schema()
    normalized_geo_scope = _normalize_scope_values(geo_head_names)
    request_where: list[str] = []
    request_params: list[Any] = []
    project_where_sql = ""
    project_params: list[Any] = []

    if normalized_geo_scope:
        project_where_sql = "and lower(trim(coalesce(r.geo_head, ''))) = any(%s)"
        project_params.append(normalized_geo_scope)
        request_where.append("lower(trim(coalesce(pr.geo_head, ''))) = any(%s)")
        request_params.append(normalized_geo_scope)

    normalized_status = str(status or "").strip().lower()
    if normalized_status in {"pending", "approved", "rejected"}:
        request_where.append("pr.status = %s")
        request_params.append(normalized_status)

    request_where_sql = f"where {' and '.join(request_where)}" if request_where else ""

    with open_database_connection(require=True) as connection:
        assert connection is not None
        with connection.cursor() as cursor:
            cursor.execute(
                f"""
                select
                    r.id as record_id,
                    coalesce(r.customer_name, '') as customer_name,
                    coalesce(r.project_name, '') as project_name,
                    coalesce(r.ms_ps, '') as ms_ps,
                    coalesce(r.entity, '') as entity,
                    coalesce(r.practice_head, '') as practice_head,
                    coalesce(r.geo_head, '') as geo_head,
                    coalesce(r.bdm, '') as current_bdm,
                    r.raw_payload,
                    pending.id::text as pending_request_id,
                    pending.requested_bdm as pending_requested_bdm,
                    pending.created_at as pending_created_at
                from rapid_revenue_records r
                join rapid_revenue_uploads u on u.id = r.upload_id
                left join lateral (
                    select pr.id, pr.requested_bdm, pr.created_at
                    from rapid_project_assignment_requests pr
                    where pr.record_id = r.id and pr.status = 'pending'
                    order by pr.created_at desc
                    limit 1
                ) pending on true
                where u.is_active = true
                  and nullif(trim(coalesce(r.customer_name, '')), '') is not null
                  {project_where_sql}
                order by lower(coalesce(r.customer_name, '')), lower(coalesce(r.project_name, '')), r.id asc
                """,
                project_params,
            )
            project_rows = cursor.fetchall()

            cursor.execute(
                """
                select distinct coalesce(nullif(trim(r.bdm), ''), '') as value
                from rapid_revenue_records r
                join rapid_revenue_uploads u on u.id = r.upload_id
                where u.is_active = true
                order by value asc
                """
            )
            bdm_rows = cursor.fetchall()

            cursor.execute(
                """
                select distinct coalesce(nullif(trim(r.geo_head), ''), '') as value
                from rapid_revenue_records r
                join rapid_revenue_uploads u on u.id = r.upload_id
                where u.is_active = true
                order by value asc
                """
            )
            geo_head_rows = cursor.fetchall()

            cursor.execute(
                """
                select distinct coalesce(nullif(trim(r.practice_head), ''), '') as value
                from rapid_revenue_records r
                join rapid_revenue_uploads u on u.id = r.upload_id
                where u.is_active = true
                order by value asc
                """
            )
            practice_head_rows = cursor.fetchall()

            cursor.execute(
                f"""
                select
                    pr.id::text as id,
                    pr.record_id,
                    pr.customer_name,
                    pr.project_name,
                    pr.geo_head,
                    pr.practice_head,
                    pr.current_bdm,
                    pr.requested_bdm,
                    pr.requested_by_user_id,
                    pr.requested_by_name,
                    pr.status,
                    pr.decision_note,
                    pr.created_at,
                    pr.decided_at,
                    pr.decided_by_user_id,
                    pr.decided_by_name
                from rapid_project_assignment_requests pr
                {request_where_sql}
                order by pr.created_at desc
                limit 240
                """,
                request_params,
            )
            request_rows = cursor.fetchall()

    configured_bdm_options = _list_configured_bdm_options()
    configured_practice_head_options = _list_configured_practice_head_options()
    configured_geo_head_options = _list_configured_geo_head_options()
    merged_bdm_options: dict[str, str] = {}
    for row in bdm_rows:
        value = str(row.get("value") or "").strip()
        if value:
            merged_bdm_options.setdefault(value.lower(), value)
    for value in configured_bdm_options:
        merged_bdm_options.setdefault(value.lower(), value)

    merged_practice_head_options: dict[str, str] = {}
    for row in practice_head_rows:
        value = str(row.get("value") or "").strip()
        if value:
            merged_practice_head_options.setdefault(value.lower(), value)
    for value in configured_practice_head_options:
        merged_practice_head_options.setdefault(value.lower(), value)

    merged_geo_head_options: dict[str, str] = {}
    for row in geo_head_rows:
        value = str(row.get("value") or "").strip()
        if value:
            merged_geo_head_options.setdefault(value.lower(), value)
    for value in configured_geo_head_options:
        merged_geo_head_options.setdefault(value.lower(), value)

    def _serialize_project_row(row: dict[str, Any]) -> dict[str, Any]:
        metadata = _read_assignment_metadata(row.get("raw_payload"))
        return {
            "recordId": int(row.get("record_id") or 0),
            "customerName": str(row.get("customer_name") or ""),
            "projectName": str(row.get("project_name") or ""),
            "msps": str(row.get("ms_ps") or ""),
            "entity": str(row.get("entity") or ""),
            "practiceHead": str(row.get("practice_head") or ""),
            "geoHead": str(row.get("geo_head") or ""),
            "currentBdm": str(row.get("current_bdm") or ""),
            "assignmentType": str(metadata.get("type") or ""),
            "assignmentDirection": str(metadata.get("direction") or ""),
            "assignmentFrom": str(metadata.get("from") or ""),
            "assignmentTo": str(metadata.get("to") or ""),
            "assignmentEffectiveMonth": str(metadata.get("effectiveMonth") or ""),
            "pendingRequestId": str(row.get("pending_request_id") or ""),
            "pendingRequestedBdm": str(row.get("pending_requested_bdm") or ""),
            "pendingCreatedAt": _serialize_timestamp(row.get("pending_created_at")),
            "status": "awaiting" if row.get("pending_request_id") else "ready",
        }

    return {
        "projects": [_serialize_project_row(row) for row in project_rows],
        "bdmOptions": [
            value
            for _, value in sorted(merged_bdm_options.items(), key=lambda item: item[1].lower())
        ],
        "geoHeadOptions": [
            value
            for _, value in sorted(merged_geo_head_options.items(), key=lambda item: item[1].lower())
        ],
        "practiceHeadOptions": [
            value
            for _, value in sorted(merged_practice_head_options.items(), key=lambda item: item[1].lower())
        ],
        "monthOptions": list(SUPPORTED_FORECAST_MONTHS),
        "requests": [_serialize_project_assignment_request(row) for row in request_rows],
    }


def create_project_assignment_request(
    *,
    user_id: str,
    user_name: str,
    record_id: int,
    next_bdm: str,
) -> dict[str, Any]:
    ensure_postgres_schema()
    target_bdm = str(next_bdm or "").strip()
    if not target_bdm:
        raise HTTPException(status_code=400, detail="BDM is required.")

    now_iso = utc_now_iso()
    with open_database_connection(require=True) as connection:
        assert connection is not None
        with connection.cursor() as cursor:
            cursor.execute(
                """
                select
                    r.id,
                    coalesce(r.customer_name, '') as customer_name,
                    coalesce(r.project_name, '') as project_name,
                    coalesce(r.geo_head, '') as geo_head,
                    coalesce(r.practice_head, '') as practice_head,
                    coalesce(r.bdm, '') as current_bdm
                from rapid_revenue_records r
                join rapid_revenue_uploads u on u.id = r.upload_id
                where r.id = %s and u.is_active = true
                limit 1
                """,
                (record_id,),
            )
            row = cursor.fetchone()
            if not row:
                raise HTTPException(status_code=404, detail="Project row not found.")

            current_bdm = str(row.get("current_bdm") or "").strip()
            if current_bdm.lower() == target_bdm.lower():
                raise HTTPException(status_code=400, detail="Choose a different BDM to create a reassignment request.")

            cursor.execute(
                """
                select id::text as id
                from rapid_project_assignment_requests
                where record_id = %s and status = 'pending'
                order by created_at desc
                limit 1
                """,
                (record_id,),
            )
            existing = cursor.fetchone()
            request_id = str(existing.get("id") or "") if existing else str(uuid4())

            if existing:
                cursor.execute(
                    """
                    update rapid_project_assignment_requests
                    set requested_bdm = %s,
                        current_bdm = %s,
                        requested_by_user_id = %s,
                        requested_by_name = %s,
                        decision_note = null,
                        created_at = %s::timestamptz,
                        decided_at = null,
                        decided_by_user_id = null,
                        decided_by_name = null
                    where id::text = %s
                    """,
                    (target_bdm, current_bdm, user_id, user_name, now_iso, request_id),
                )
            else:
                cursor.execute(
                    """
                    insert into rapid_project_assignment_requests (
                        id,
                        record_id,
                        customer_name,
                        project_name,
                        geo_head,
                        practice_head,
                        current_bdm,
                        requested_bdm,
                        requested_by_user_id,
                        requested_by_name,
                        status,
                        created_at
                    )
                    values (%s, %s, %s, %s, %s, %s, %s, %s, %s, %s, 'pending', %s::timestamptz)
                    """,
                    (
                        request_id,
                        record_id,
                        str(row.get("customer_name") or ""),
                        str(row.get("project_name") or ""),
                        str(row.get("geo_head") or ""),
                        str(row.get("practice_head") or ""),
                        current_bdm,
                        target_bdm,
                        user_id,
                        user_name,
                        now_iso,
                    ),
                )

            cursor.execute(
                """
                insert into rapid_notifications (
                    id,
                    category,
                    audience_role,
                    audience_user_id,
                    title,
                    message,
                    link,
                    created_at,
                    metadata
                )
                values (%s, %s, %s, %s, %s, %s, %s, %s::timestamptz, %s::jsonb)
                """,
                (
                    str(uuid4()),
                    "project_assignment_approval_required",
                    "geo-head",
                    None,
                    f"Approval required for {str(row.get('customer_name') or 'customer')}",
                    (
                        f"{user_name} requested moving {str(row.get('project_name') or 'the project')} "
                        f"from {current_bdm or 'Unassigned'} to {target_bdm}."
                    ),
                    "/notifications",
                    now_iso,
                    json.dumps(
                        {
                            "requestId": request_id,
                            "recordId": record_id,
                            "customerName": str(row.get("customer_name") or ""),
                            "projectName": str(row.get("project_name") or ""),
                            "currentBdm": current_bdm,
                            "requestedBdm": target_bdm,
                            "targetGeoHead": str(row.get("geo_head") or ""),
                        }
                    ),
                ),
            )

            cursor.execute(
                """
                select
                    id::text as id,
                    record_id,
                    customer_name,
                    project_name,
                    geo_head,
                    practice_head,
                    current_bdm,
                    requested_bdm,
                    requested_by_user_id,
                    requested_by_name,
                    status,
                    decision_note,
                    created_at,
                    decided_at,
                    decided_by_user_id,
                    decided_by_name
                from rapid_project_assignment_requests
                where id::text = %s
                limit 1
                """,
                (request_id,),
            )
            request_row = cursor.fetchone()
        connection.commit()

    return {
        "status": "awaiting",
        "request": _serialize_project_assignment_request(request_row or {}),
    }


def decide_project_assignment_request(
    *,
    user_id: str,
    user_name: str,
    geo_head_names: list[str],
    request_id: str,
    decision: str,
    note: str | None = None,
) -> dict[str, Any]:
    ensure_postgres_schema()
    normalized_geo_scope = set(_normalize_scope_values(geo_head_names))
    normalized_decision = str(decision or "").strip().lower()
    if normalized_decision not in {"approved", "rejected"}:
        raise HTTPException(status_code=400, detail="Decision must be approved or rejected.")

    now_iso = utc_now_iso()
    with open_database_connection(require=True) as connection:
        assert connection is not None
        with connection.cursor() as cursor:
            cursor.execute(
                """
                select
                    id::text as id,
                    record_id,
                    customer_name,
                    project_name,
                    geo_head,
                    practice_head,
                    current_bdm,
                    requested_bdm,
                    requested_by_user_id,
                    requested_by_name,
                    status,
                    decision_note,
                    created_at,
                    decided_at,
                    decided_by_user_id,
                    decided_by_name
                from rapid_project_assignment_requests
                where id::text = %s
                limit 1
                """,
                (request_id,),
            )
            row = cursor.fetchone()
            if not row:
                raise HTTPException(status_code=404, detail="Approval request not found.")
            if str(row.get("status") or "").strip().lower() != "pending":
                raise HTTPException(status_code=400, detail="This approval request is already closed.")

            scoped_geo = str(row.get("geo_head") or "").strip().lower()
            if normalized_geo_scope and scoped_geo not in normalized_geo_scope:
                raise HTTPException(status_code=403, detail="This request is outside your geo scope.")

            if normalized_decision == "approved":
                cursor.execute(
                    """
                    update rapid_revenue_records
                    set bdm = %s
                    where id = %s
                    """,
                    (str(row.get("requested_bdm") or ""), int(row.get("record_id") or 0)),
                )

            cursor.execute(
                """
                update rapid_project_assignment_requests
                set status = %s,
                    decision_note = %s,
                    decided_at = %s::timestamptz,
                    decided_by_user_id = %s,
                    decided_by_name = %s
                where id::text = %s
                """,
                (normalized_decision, _clean_text(note) or None, now_iso, user_id, user_name, request_id),
            )

            decision_message = (
                f"{user_name} approved the reassignment to {str(row.get('requested_bdm') or '')}."
                if normalized_decision == "approved"
                else f"{user_name} rejected the reassignment to {str(row.get('requested_bdm') or '')}."
            )
            metadata = json.dumps(
                {
                    "requestId": request_id,
                    "recordId": int(row.get("record_id") or 0),
                    "customerName": str(row.get("customer_name") or ""),
                    "projectName": str(row.get("project_name") or ""),
                    "requestedBdm": str(row.get("requested_bdm") or ""),
                    "decision": normalized_decision,
                    "targetGeoHead": str(row.get("geo_head") or ""),
                }
            )
            cursor.executemany(
                """
                insert into rapid_notifications (
                    id,
                    category,
                    audience_role,
                    audience_user_id,
                    title,
                    message,
                    link,
                    created_at,
                    metadata
                )
                values (%s, %s, %s, %s, %s, %s, %s, %s::timestamptz, %s::jsonb)
                """,
                [
                    (
                        str(uuid4()),
                        f"project_assignment_{normalized_decision}",
                        "executive",
                        None,
                        f"Project reassignment {normalized_decision}",
                        decision_message,
                        "/notifications",
                        now_iso,
                        metadata,
                    ),
                    (
                        str(uuid4()),
                        f"project_assignment_{normalized_decision}",
                        None,
                        str(row.get("requested_by_user_id") or ""),
                        f"Your reassignment request was {normalized_decision}",
                        decision_message,
                        "/notifications",
                        now_iso,
                        metadata,
                    ),
                ],
            )

            cursor.execute(
                """
                select
                    id::text as id,
                    record_id,
                    customer_name,
                    project_name,
                    geo_head,
                    practice_head,
                    current_bdm,
                    requested_bdm,
                    requested_by_user_id,
                    requested_by_name,
                    status,
                    decision_note,
                    created_at,
                    decided_at,
                    decided_by_user_id,
                    decided_by_name
                from rapid_project_assignment_requests
                where id::text = %s
                limit 1
                """,
                (request_id,),
            )
            request_row = cursor.fetchone()
        connection.commit()

    return {
        "status": normalized_decision,
        "request": _serialize_project_assignment_request(request_row or {}),
    }


def get_notifications(
    role_id: str,
    user_id: str,
    bdm_names: list[str] | None = None,
    practice_head_names: list[str] | None = None,
    geo_head_names: list[str] | None = None,
) -> dict[str, Any]:
    ensure_postgres_schema()
    bdm_names = bdm_names or []
    normalized_geo_scope = set(_normalize_scope_values(geo_head_names))
    notifications: list[dict[str, Any]] = []

    with open_database_connection(require=True) as connection:
        assert connection is not None
        with connection.cursor() as cursor:
            if role_id in {"executive", "superuser"}:
                cursor.execute(
                    """
                    select id::text as id, category, title, message, link, created_at, metadata
                    from rapid_notifications
                    where audience_role in ('executive', 'all') or audience_user_id = %s
                    order by created_at desc
                    limit 20
                    """,
                    (user_id,),
                )
            elif role_id in {"geo-head", "practice-head"}:
                cursor.execute(
                    """
                    select id::text as id, category, title, message, link, created_at, metadata
                    from rapid_notifications
                    where audience_role in (%s, 'executive', 'all') or audience_user_id = %s
                    order by created_at desc
                    limit 40
                    """,
                    (role_id, user_id),
                )
            else:
                cursor.execute(
                    """
                    select id::text as id, category, title, message, link, created_at, metadata
                    from rapid_notifications
                    where audience_user_id = %s or audience_role in ('bdm', 'all')
                    order by created_at desc
                    limit 20
                    """,
                    (user_id,),
                )
            rows = cursor.fetchall()

        for row in rows:
            metadata = row.get("metadata") or {}
            if isinstance(metadata, str):
                try:
                    metadata = json.loads(metadata)
                except json.JSONDecodeError:
                    metadata = {}
            if not isinstance(metadata, dict):
                metadata = {}
            if (
                role_id == "geo-head"
                and str(row.get("category") or "") == "project_assignment_approval_required"
                and normalized_geo_scope
            ):
                target_geo = str(metadata.get("targetGeoHead") or "").strip().lower()
                if target_geo and target_geo not in normalized_geo_scope:
                    continue
            notifications.append(
                {
                    "id": row["id"],
                    "category": str(row.get("category") or "info"),
                    "title": str(row.get("title") or "Notification"),
                    "message": str(row.get("message") or ""),
                    "link": str(row.get("link") or ""),
                    "createdAt": _serialize_timestamp(row.get("created_at")) or utc_now_iso(),
                    "metadata": metadata,
                }
            )

    if role_id in {"executive", "superuser"}:
        notifications.extend(_build_missing_forecast_notifications())
    elif role_id == "bdm" and bdm_names:
        notifications.extend(_build_bdm_deadline_notifications(bdm_names))

    notifications.sort(key=lambda item: item.get("createdAt") or "", reverse=True)
    return {
        "notifications": notifications[:20],
        "forecastSubmissionMatrix": _build_forecast_submission_matrix(
            bdm_names=bdm_names,
            practice_head_names=practice_head_names,
            geo_head_names=geo_head_names,
        ),
    }


def _build_missing_forecast_notifications() -> list[dict[str, Any]]:
    ensure_postgres_schema()
    today = date.today()
    if today.day <= FORECAST_CUTOFF_DAY:
        return []

    month_label = resolve_current_forecast_month()
    with open_database_connection(require=True) as connection:
        assert connection is not None
        with connection.cursor() as cursor:
            cursor.execute(
                """
                with scoped_bdms as (
                    select distinct bdm
                    from rapid_revenue_records r
                    join rapid_revenue_uploads u on u.id = r.upload_id
                    where u.is_active = true and coalesce(r.bdm, '') <> ''
                ),
                submitted as (
                    select distinct r.bdm
                    from rapid_forecast_entries f
                    join rapid_revenue_records r on r.id = f.record_id
                    where f.forecast_month = %s and coalesce(r.bdm, '') <> ''
                )
                select bdm from scoped_bdms where bdm not in (select bdm from submitted)
                order by bdm asc
                """,
                (month_label,),
            )
            rows = cursor.fetchall()

    created_at = datetime.combine(today, datetime.min.time(), tzinfo=timezone.utc).isoformat().replace("+00:00", "Z")
    return [
        {
            "id": f"missing-{month_label}-{row['bdm']}",
            "category": "forecast_missing",
            "title": f"Forecast overdue for {row['bdm']}",
            "message": f"{row['bdm']} has not submitted {month_label} forecast after the day {FORECAST_CUTOFF_DAY} cutoff.",
            "link": "/notifications",
            "createdAt": created_at,
        }
        for row in rows
    ]


def _build_forecast_submission_matrix(
    *,
    bdm_names: list[str] | None = None,
    practice_head_names: list[str] | None = None,
    geo_head_names: list[str] | None = None,
) -> dict[str, Any]:
    ensure_postgres_schema()
    current_month = resolve_current_forecast_month()
    month_list = list(SUPPORTED_FORECAST_MONTHS)
    current_index = month_list.index(current_month) if current_month in MONTH_KEY_BY_LABEL else 0
    normalized_bdms = _normalize_scope_values(bdm_names)
    normalized_practice_heads = _normalize_scope_values(practice_head_names)
    normalized_geo_heads = _normalize_scope_values(geo_head_names)
    scope_clauses = [
        "u.is_active = true",
        "coalesce(r.raw_payload->'Assignment Split'->>'direction', '') <> 'outgoing'",
    ]
    scope_params: list[Any] = []
    if normalized_bdms:
        scope_clauses.append("lower(trim(coalesce(r.bdm, ''))) = any(%s)")
        scope_params.append(normalized_bdms)
    if normalized_practice_heads:
        scope_clauses.append("lower(trim(coalesce(r.practice_head, ''))) = any(%s)")
        scope_params.append(normalized_practice_heads)
    if normalized_geo_heads:
        scope_clauses.append("lower(trim(coalesce(r.geo_head, ''))) = any(%s)")
        scope_params.append(normalized_geo_heads)
    scope_sql = " and ".join(scope_clauses)
    bdm_columns: list[str] = []
    practice_head_columns: list[str] = []
    submitted_at_by_key: dict[tuple[str, str, str], str | None] = {}

    with open_database_connection(require=True) as connection:
        assert connection is not None
        with connection.cursor() as cursor:
            cursor.execute(
                f"""
                select distinct nullif(trim(coalesce(r.bdm, '')), '') as owner_name
                from rapid_revenue_records r
                join rapid_revenue_uploads u on u.id = r.upload_id
                where {scope_sql}
                  and nullif(trim(coalesce(r.bdm, '')), '') is not null
                order by owner_name asc
                """,
                scope_params,
            )
            bdm_columns = [
                str(row.get("owner_name") or "").strip()
                for row in cursor.fetchall()
                if str(row.get("owner_name") or "").strip()
            ]

            cursor.execute(
                f"""
                select distinct nullif(trim(coalesce(r.practice_head, '')), '') as owner_name
                from rapid_revenue_records r
                join rapid_revenue_uploads u on u.id = r.upload_id
                where {scope_sql}
                  and nullif(trim(coalesce(r.practice_head, '')), '') is not null
                order by owner_name asc
                """,
                scope_params,
            )
            practice_head_columns = [
                str(row.get("owner_name") or "").strip()
                for row in cursor.fetchall()
                if str(row.get("owner_name") or "").strip()
            ]

            cursor.execute(
                f"""
                select
                    f.forecast_month,
                    f.submitter_role,
                    case
                      when f.submitter_role = 'bdm'
                      then nullif(trim(coalesce(r.bdm, '')), '')
                      when f.submitter_role = 'practice-head'
                      then nullif(trim(coalesce(r.practice_head, '')), '')
                      else null
                    end as owner_name,
                    max(f.submitted_at) as submitted_at
                from rapid_forecast_role_entries f
                join rapid_revenue_records r on r.id = f.record_id
                join rapid_revenue_uploads u on u.id = r.upload_id
                where {scope_sql}
                  and f.submitter_role in ('bdm', 'practice-head')
                  and f.forecast_month = any(%s)
                group by f.forecast_month, f.submitter_role, owner_name
                """,
                [*scope_params, month_list],
            )
            for row in cursor.fetchall():
                month = str(row.get("forecast_month") or "").strip()
                role = str(row.get("submitter_role") or "").strip()
                owner_name = str(row.get("owner_name") or "").strip()
                if month not in MONTH_KEY_BY_LABEL or role not in {"bdm", "practice-head"} or not owner_name:
                    continue
                submitted_at_by_key[(month, role, owner_name.lower())] = _serialize_timestamp(
                    row.get("submitted_at")
                )

    def build_column(role: str, label: str) -> dict[str, Any]:
        return {
            "key": f"{role}::{label}",
            "label": label,
            "role": role,
        }

    columns = {
        "bdm": [build_column("bdm", label) for label in bdm_columns],
        "practiceHead": [build_column("practice-head", label) for label in practice_head_columns],
    }
    all_columns = [*columns["bdm"], *columns["practiceHead"]]

    def build_cell(month: str, role: str, owner_name: str, future: bool) -> dict[str, Any]:
        submitted_at = submitted_at_by_key.get((month, role, owner_name.lower()))
        status = "future" if future else "complete" if submitted_at else "pending"
        return {
            "status": status,
            "submittedAt": submitted_at,
        }

    return {
        "columns": columns,
        "rows": [
            {
                "month": month,
                "future": index > current_index,
                "cells": {
                    column["key"]: build_cell(
                        month,
                        str(column["role"] or ""),
                        str(column["label"] or ""),
                        index > current_index,
                    )
                    for column in all_columns
                },
            }
            for index, month in enumerate(month_list)
        ],
    }


def _build_bdm_deadline_notifications(bdm_names: list[str]) -> list[dict[str, Any]]:
    ensure_postgres_schema()
    month_label = resolve_current_forecast_month()
    today = date.today()
    if today.day <= FORECAST_CUTOFF_DAY:
        return []

    normalized_bdms = [
        str(value).strip().lower()
        for value in bdm_names
        if str(value).strip()
    ]
    if not normalized_bdms:
        return []

    with open_database_connection(require=True) as connection:
        assert connection is not None
        with connection.cursor() as cursor:
            cursor.execute(
                """
                select distinct r.bdm
                from rapid_revenue_records r
                join rapid_revenue_uploads u on u.id = r.upload_id
                where u.is_active = true and lower(trim(coalesce(r.bdm, ''))) = any(%s)
                except
                select distinct r.bdm
                from rapid_forecast_entries f
                join rapid_revenue_records r on r.id = f.record_id
                where f.forecast_month = %s and lower(trim(coalesce(r.bdm, ''))) = any(%s)
                """,
                (normalized_bdms, month_label, normalized_bdms),
            )
            rows = cursor.fetchall()

    created_at = datetime.combine(today, datetime.min.time(), tzinfo=timezone.utc).isoformat().replace("+00:00", "Z")
    return [
        {
            "id": f"bdm-missing-{month_label}-{row['bdm']}",
            "category": "forecast_reminder",
            "title": f"{month_label} forecast is overdue",
            "message": f"Your {month_label} forecast is still pending. Leadership can already see this exception.",
            "link": "/bdm/forecast",
            "createdAt": created_at,
        }
        for row in rows
    ]


def resolve_current_forecast_month(today: date | None = None) -> str:
    current = today or date.today()
    candidate = current.strftime("%b %Y")
    if candidate in MONTH_KEY_BY_LABEL:
        return candidate
    if current.month < 4:
        return "Jan 2027"
    if current.month > 12:
        return "Mar 2027"
    month_index = max(0, min(current.month - 4, len(RAPID_REVENUE_MONTH_FIELDS) - 1))
    return RAPID_REVENUE_MONTH_FIELDS[month_index]


def _resolve_visible_months(rollout_start_month: str) -> list[str]:
    return list(SUPPORTED_FORECAST_MONTHS)


def _normalize_configured_month(rollout_start_month: str) -> str:
    normalized = str(rollout_start_month or "").strip()
    if normalized in MONTH_KEY_BY_LABEL:
        return normalized
    return DEFAULT_ROLLOUT_START_MONTH


def _resolve_active_month(rollout_start_month: str, *, today: date | None = None) -> str:
    configured_month = _normalize_configured_month(rollout_start_month)
    current_month = resolve_current_forecast_month(today)
    configured_index = list(SUPPORTED_FORECAST_MONTHS).index(configured_month)
    current_index = list(SUPPORTED_FORECAST_MONTHS).index(
        current_month if current_month in MONTH_KEY_BY_LABEL else DEFAULT_ROLLOUT_START_MONTH
    )
    return list(SUPPORTED_FORECAST_MONTHS)[max(configured_index, current_index)]


def _resolve_locked_months(active_month: str) -> list[str]:
    normalized = _resolve_active_month(active_month)
    start_index = list(SUPPORTED_FORECAST_MONTHS).index(normalized)
    return list(SUPPORTED_FORECAST_MONTHS[:start_index])


def _resolve_editable_months(active_month: str, *, window_open: bool) -> list[str]:
    # Editing remains available for active months even when the submission
    # window is outside lock-in / lock-out dates.
    _ = window_open
    normalized = _resolve_active_month(active_month)
    start_index = list(SUPPORTED_FORECAST_MONTHS).index(normalized)
    return list(SUPPORTED_FORECAST_MONTHS[start_index:])


def _resolve_forecast_window_dates(
    lockin_day: int,
    lockout_day: int,
    *,
    lockin_date: date | None,
    lockout_date: date | None,
    today: date | None = None,
) -> tuple[date | None, date | None]:
    if lockin_date and lockout_date:
        return lockin_date, lockout_date

    reference = today or date.today()
    days_in_month = calendar.monthrange(reference.year, reference.month)[1]
    resolved_lockin = date(reference.year, reference.month, min(max(lockin_day, 1), days_in_month))
    resolved_lockout = date(reference.year, reference.month, min(max(lockout_day, 1), days_in_month))
    if resolved_lockout < resolved_lockin:
        resolved_lockout = resolved_lockin
    return resolved_lockin, resolved_lockout


def _is_submission_window_open(
    lockin_day: int,
    lockout_day: int,
    *,
    lockin_date: date | None = None,
    lockout_date: date | None = None,
    today: date | None = None,
) -> bool:
    current_date = today or date.today()
    if lockin_date and lockout_date:
        return lockin_date <= current_date <= lockout_date
    current_day = int(current_date.day)
    return lockin_day <= current_day <= lockout_day


def _format_forecast_window_message(
    lockin_day: int,
    lockout_day: int,
    *,
    lockin_date: date | None = None,
    lockout_date: date | None = None,
) -> str:
    if lockin_date and lockout_date:
        return f"between {lockin_date.isoformat()} and {lockout_date.isoformat()}"
    return f"between day {lockin_day} and day {lockout_day}"


def _build_forecast_control_payload(
    *,
    lockin_day: int,
    lockout_day: int,
    lockin_date: date | None,
    lockout_date: date | None,
    rollout_start_month: str,
    updated_by: str | None,
    updated_at: Any,
) -> dict[str, Any]:
    configured_month = _normalize_configured_month(rollout_start_month)
    active_month = _resolve_active_month(configured_month)
    resolved_lockin_date, resolved_lockout_date = _resolve_forecast_window_dates(
        lockin_day,
        lockout_day,
        lockin_date=lockin_date,
        lockout_date=lockout_date,
    )
    window_open = _is_submission_window_open(
        lockin_day,
        lockout_day,
        lockin_date=lockin_date,
        lockout_date=lockout_date,
    )
    return {
        "lockinDay": lockin_day,
        "lockoutDay": lockout_day,
        "lockinDate": _serialize_date(resolved_lockin_date),
        "lockoutDate": _serialize_date(resolved_lockout_date),
        "rolloutStartMonth": configured_month,
        "activeMonth": active_month,
        "visibleMonths": _resolve_visible_months(active_month),
        "lockedMonths": _resolve_locked_months(active_month),
        "editableMonths": _resolve_editable_months(active_month, window_open=window_open),
        "submissionWindowOpen": window_open,
        "updatedBy": updated_by,
        "updatedAt": _serialize_timestamp(updated_at),
    }


