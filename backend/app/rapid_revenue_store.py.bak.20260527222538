def _normalize_country(value: str) -> str:
    text = str(value or "").strip()
    return text or "Global"


def _get_working_days_lookup(month_label: str) -> dict[str, int]:
    if month_label not in MONTH_KEY_BY_LABEL:
        return {"global": DEFAULT_WORKING_DAYS}

    ensure_postgres_schema()
    with open_database_connection(require=True) as connection:
        assert connection is not None
        with connection.cursor() as cursor:
            cursor.execute(
                """
                select country, working_days
                from rapid_country_working_days
                where month_label = %s
                """,
                (month_label,),
            )
            rows = cursor.fetchall()

    mapping = {
        _normalize_country(str(row.get("country") or "Global")).lower(): int(
            row.get("working_days") or DEFAULT_WORKING_DAYS
        )
        for row in rows
    }
    if "global" not in mapping:
        mapping["global"] = DEFAULT_WORKING_DAYS
    return mapping


def _get_customer_working_days_lookup(month_label: str) -> dict[tuple[str, str, str, str], int]:
    if month_label not in MONTH_KEY_BY_LABEL:
        return {}

    ensure_postgres_schema()
    with open_database_connection(require=True) as connection:
        assert connection is not None
        with connection.cursor() as cursor:
            cursor.execute(
                """
                select customer_name, bdm, practice_head, geo_head, working_days
                from rapid_customer_working_days
                where month_label = %s
                """,
                (month_label,),
            )
            rows = cursor.fetchall()

    return {
        _build_customer_scope_key(
            customer_name=row.get("customer_name"),
            bdm=row.get("bdm"),
            practice_head=row.get("practice_head"),
            geo_head=row.get("geo_head"),
        ): int(row.get("working_days") or DEFAULT_WORKING_DAYS)
        for row in rows
    }


def _resolve_submission_numeric_value(
    has_value: bool,
    payload_value: Any,
    existing_value: Any,
) -> float:
    if has_value:
        parsed = _parse_optional_numeric(payload_value)
        if parsed is not None:
            return parsed
        return 0.0
    if existing_value in (None, ""):
        return 0.0
    return _parse_numeric(existing_value)


def _coerce_non_negative_numeric(value: Any) -> float:
    return max(_to_float(value), 0.0)


def _sanitize_forecast_value_against_budget(
    forecast_value: Any,
    budget_value: Any,
) -> float:
    sanitized_forecast_value = _to_float(forecast_value)
    sanitized_budget_value = _to_float(budget_value)
    if sanitized_forecast_value < 0 <= sanitized_budget_value:
        return sanitized_budget_value
    return sanitized_forecast_value


def _convert_local_budget_to_usd(value: Any, currency: Any, forex: Any) -> float:
    amount = _to_float(value)
    normalized_currency = str(currency or "USD").strip().upper()
    if normalized_currency == "USD":
        return amount
    forex_rate = _to_float(forex)
    if forex_rate > 0:
        return amount / forex_rate
    return amount


def _sanitize_negative_forecast_snapshots(cursor: Any, forecast_month: str) -> None:
    month_key = MONTH_KEY_BY_LABEL.get(forecast_month)
    if not month_key:
        return
    budget_usd_sql = f"""
        case
          when upper(coalesce(nullif(trim(r.billed_currency), ''), 'USD')) = 'USD'
          then coalesce(r.{month_key}, 0)
          when coalesce(r.forex, 0) > 0
          then coalesce(r.{month_key}, 0) / r.forex
          else coalesce(r.{month_key}, 0)
        end
    """
    cursor.execute(
        f"""
        update rapid_forecast_entries f
        set forecast_value = {budget_usd_sql}
        from rapid_revenue_records r
        join rapid_revenue_uploads u on u.id = r.upload_id
        where f.record_id = r.id
          and f.forecast_month = %s
          and u.is_active = true
          and coalesce(f.forecast_value, 0) < 0
          and coalesce(r.{month_key}, 0) >= 0
        """,
        (forecast_month,),
    )
    cursor.execute(
        f"""
        update rapid_forecast_drafts d
        set forecast_value = {budget_usd_sql}
        from rapid_revenue_records r
        join rapid_revenue_uploads u on u.id = r.upload_id
        where d.record_id = r.id
          and d.forecast_month = %s
          and u.is_active = true
          and coalesce(d.forecast_value, 0) < 0
          and coalesce(r.{month_key}, 0) >= 0
        """,
        (forecast_month,),
    )


