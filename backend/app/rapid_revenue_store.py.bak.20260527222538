def get_country_working_days() -> dict[str, Any]:
    ensure_postgres_schema()
    ensure_budget_sync_to_rapid_revenue()
    months = list(SUPPORTED_FORECAST_MONTHS)
    rows_by_country: dict[str, dict[str, int]] = {}

    with open_database_connection(require=True) as connection:
        assert connection is not None
        with connection.cursor() as cursor:
            cursor.execute(
                """
                select country, month_label, working_days
                from rapid_country_working_days
                order by lower(country), month_label
                """
            )
            rows = cursor.fetchall()
            cursor.execute(
                """
                select distinct coalesce(nullif(trim(r.row_us), ''), 'Global') as country
                from rapid_revenue_records r
                join rapid_revenue_uploads u on u.id = r.upload_id
                where u.is_active = true
                order by country asc
                """
            )
            country_rows = cursor.fetchall()

    for row in rows:
        country = _normalize_country(str(row.get("country") or "Global"))
        month_label = str(row.get("month_label") or "").strip()
        if month_label not in MONTH_KEY_BY_LABEL:
            continue
        rows_by_country.setdefault(country, {})[month_label] = int(
            row.get("working_days") or DEFAULT_WORKING_DAYS
        )

    discovered_countries = [
        _normalize_country(str(row.get("country") or "Global"))
        for row in country_rows
        if str(row.get("country") or "").strip()
    ]
    countries = sorted(set(["Global", *discovered_countries, *rows_by_country.keys()]))

    normalized_rows: list[dict[str, Any]] = []
    for country in countries:
        working_days = {
            month: max(
                0,
                min(
                    31,
                    int(
                        rows_by_country.get(country, {}).get(
                            month,
                            rows_by_country.get("Global", {}).get(month, DEFAULT_WORKING_DAYS),
                        )
                    ),
                ),
            )
            for month in months
        }
        normalized_rows.append(
            {
                "country": country,
                "workingDays": working_days,
            }
        )

    return {
        "months": months,
        "rows": normalized_rows,
        "countries": countries,
    }


def get_customer_holidays(
    *,
    bdms: list[str] | None = None,
    practice_heads: list[str] | None = None,
    geo_heads: list[str] | None = None,
) -> dict[str, Any]:
    ensure_postgres_schema()
    where_clauses: list[str] = []
    params: list[Any] = []

    normalized_bdms = [
        str(value).strip().lower()
        for value in (bdms or [])
        if str(value).strip()
    ]
    normalized_practice_heads = [
        str(value).strip().lower()
        for value in (practice_heads or [])
        if str(value).strip()
    ]
    normalized_geo_heads = [
        str(value).strip().lower()
        for value in (geo_heads or [])
        if str(value).strip()
    ]

    if normalized_bdms:
        where_clauses.append("lower(trim(coalesce(h.bdm, ''))) = any(%s)")
        params.append(normalized_bdms)
    if normalized_practice_heads:
        where_clauses.append("lower(trim(coalesce(h.practice_head, ''))) = any(%s)")
        params.append(normalized_practice_heads)
    if normalized_geo_heads:
        where_clauses.append("lower(trim(coalesce(h.geo_head, ''))) = any(%s)")
        params.append(normalized_geo_heads)

    where_sql = f"where {' and '.join(where_clauses)}" if where_clauses else ""
    project_scope_where_sql = where_sql.replace("h.", "r.")
    project_scope_sql_suffix = ""
    if project_scope_where_sql:
        normalized_scope_sql = project_scope_where_sql.removeprefix("where ").strip()
        if normalized_scope_sql:
            project_scope_sql_suffix = f" and {normalized_scope_sql}"

    with open_database_connection(require=True) as connection:
        assert connection is not None
        with connection.cursor() as cursor:
            cursor.execute(
                f"""
                select
                    h.id::text as id,
                    h.customer_name,
                    h.holiday_date,
                    h.holiday_name,
                    h.project_name,
                    h.bdm,
                    h.practice_head,
                    h.geo_head,
                    h.updated_by,
                    h.updated_at
                from rapid_customer_holidays h
                {where_sql}
                order by h.holiday_date asc, lower(h.customer_name) asc, lower(coalesce(h.project_name, '')) asc
                """,
                params,
            )
            rows = cursor.fetchall()

            cursor.execute(
                f"""
                select distinct coalesce(nullif(trim(r.customer_name), ''), '') as value
                from rapid_revenue_records r
                join rapid_revenue_uploads u on u.id = r.upload_id
                where u.is_active = true
                {project_scope_sql_suffix}
                order by value asc
                """,
                params,
            )
            customer_rows = cursor.fetchall()

            cursor.execute(
                f"""
                select distinct coalesce(nullif(trim(r.bdm), ''), '') as value
                from rapid_revenue_records r
                join rapid_revenue_uploads u on u.id = r.upload_id
                where u.is_active = true
                {project_scope_sql_suffix}
                order by value asc
                """,
                params,
            )
            bdm_rows = cursor.fetchall()

            cursor.execute(
                f"""
                select distinct coalesce(nullif(trim(r.practice_head), ''), '') as value
                from rapid_revenue_records r
                join rapid_revenue_uploads u on u.id = r.upload_id
                where u.is_active = true
                {project_scope_sql_suffix}
                order by value asc
                """,
                params,
            )
            practice_rows = cursor.fetchall()

    return {
        "rows": [
            {
                "id": str(row.get("id") or ""),
                "customerName": str(row.get("customer_name") or ""),
                "holidayDate": _serialize_date(row.get("holiday_date")),
                "holidayName": str(row.get("holiday_name") or ""),
                "projectName": str(row.get("project_name") or ""),
                "bdm": str(row.get("bdm") or ""),
                "practiceHead": str(row.get("practice_head") or ""),
                "geoHead": str(row.get("geo_head") or ""),
                "updatedBy": str(row.get("updated_by") or ""),
                "updatedAt": _serialize_timestamp(row.get("updated_at")),
            }
            for row in rows
        ],
        "filters": {
            "customers": [
                str(row.get("value") or "")
                for row in customer_rows
                if str(row.get("value") or "")
            ],
            "bdms": [
                str(row.get("value") or "")
                for row in bdm_rows
                if str(row.get("value") or "")
            ],
            "practiceHeads": [
                str(row.get("value") or "")
                for row in practice_rows
                if str(row.get("value") or "")
            ],
        },
    }


def save_customer_holidays(
    rows: list[dict[str, Any]],
    *,
    updated_by: str = "admin-settings",
) -> dict[str, Any]:
    ensure_postgres_schema()
    normalized_rows: list[tuple[str, date, str, str | None, str | None, str | None, str | None]] = []
    seen: set[tuple[str, date, str, str, str]] = set()

    for raw in rows:
        customer_name = _clean_text(raw.get("customerName"))
        if not customer_name:
            raise HTTPException(status_code=400, detail="Customer name is required for every holiday row.")

        holiday_date = _coerce_holiday_date(raw.get("holidayDate"))
        holiday_name = _clean_text(raw.get("holidayName")) or "Holiday"
        project_name = _clean_text(raw.get("projectName")) or None
        bdm = _clean_text(raw.get("bdm")) or None
        practice_head = _clean_text(raw.get("practiceHead")) or None
        geo_head = _clean_text(raw.get("geoHead")) or None

        dedupe_key = (
            customer_name.lower(),
            holiday_date,
            (project_name or "").lower(),
            (bdm or "").lower(),
            (practice_head or "").lower(),
        )
        if dedupe_key in seen:
            continue
        seen.add(dedupe_key)

        normalized_rows.append(
            (
                customer_name,
                holiday_date,
                holiday_name,
                project_name,
                bdm,
                practice_head,
                geo_head,
            )
        )

    now_iso = utc_now_iso()
    with open_database_connection(require=True) as connection:
        assert connection is not None
        with connection.cursor() as cursor:
            cursor.execute("delete from rapid_customer_holidays")
            if normalized_rows:
                cursor.executemany(
                    """
                    insert into rapid_customer_holidays (
                        id,
                        customer_name,
                        holiday_date,
                        holiday_name,
                        project_name,
                        bdm,
                        practice_head,
                        geo_head,
                        updated_by,
                        updated_at
                    )
                    values (%s, %s, %s, %s, %s, %s, %s, %s, %s, %s::timestamptz)
                    """,
                    [
                        (
                            str(uuid4()),
                            customer_name,
                            holiday_date,
                            holiday_name,
                            project_name,
                            bdm,
                            practice_head,
                            geo_head,
                            updated_by,
                            now_iso,
                        )
                        for (
                            customer_name,
                            holiday_date,
                            holiday_name,
                            project_name,
                            bdm,
                            practice_head,
                            geo_head,
                        ) in normalized_rows
                    ],
                )
        connection.commit()

    payload = get_customer_holidays()
    payload["savedAt"] = now_iso
    return payload


def save_country_working_days(
    rows: list[dict[str, Any]],
    updated_by: str = "admin-settings",
) -> dict[str, Any]:
    ensure_postgres_schema()
    normalized_rows: list[tuple[str, str, int]] = []
    months = list(SUPPORTED_FORECAST_MONTHS)

    for entry in rows:
        country = _normalize_country(str(entry.get("country") or "Global"))
        working_days_map = entry.get("workingDays")
        if not isinstance(working_days_map, dict):
            raise HTTPException(status_code=400, detail="Each country row must include workingDays.")

        for month in months:
            if month not in working_days_map:
                raise HTTPException(
                    status_code=400,
                    detail=f"Missing working days for {country} in {month}.",
                )
            try:
                working_days = int(working_days_map[month])
            except (TypeError, ValueError) as error:
                raise HTTPException(
                    status_code=400,
                    detail=f"Working days for {country} in {month} must be a number.",
                ) from error
            if working_days < 0 or working_days > 31:
                raise HTTPException(
                    status_code=400,
                    detail=f"Working days for {country} in {month} must be between 0 and 31.",
                )
            normalized_rows.append((country, month, working_days))

    now_iso = utc_now_iso()
    with open_database_connection(require=True) as connection:
        assert connection is not None
        with connection.cursor() as cursor:
            cursor.execute("delete from rapid_country_working_days")
            if normalized_rows:
                cursor.executemany(
                    """
                    insert into rapid_country_working_days (
                        id,
                        country,
                        month_label,
                        working_days,
                        updated_by,
                        updated_at
                    )
                    values (%s, %s, %s, %s, %s, %s::timestamptz)
                    """,
                    [
                        (
                            str(uuid4()),
                            country,
                            month_label,
                            working_days,
                            updated_by,
                            now_iso,
                        )
                        for country, month_label, working_days in normalized_rows
                    ],
                )
        connection.commit()

    payload = get_country_working_days()
    payload["savedAt"] = now_iso
    return payload


def get_customer_working_days(
    *,
    bdms: list[str] | None = None,
    practice_heads: list[str] | None = None,
    geo_heads: list[str] | None = None,
) -> dict[str, Any]:
    ensure_postgres_schema()
    months = list(SUPPORTED_FORECAST_MONTHS)
    normalized_bdms = _normalize_scope_values(bdms)
    normalized_practice_heads = _normalize_scope_values(practice_heads)
    normalized_geo_heads = _normalize_scope_values(geo_heads)

    revenue_where: list[str] = []
    revenue_params: list[Any] = []
    if normalized_bdms:
        revenue_where.append("lower(trim(coalesce(r.bdm, ''))) = any(%s)")
        revenue_params.append(normalized_bdms)
    if normalized_practice_heads:
        revenue_where.append("lower(trim(coalesce(r.practice_head, ''))) = any(%s)")
        revenue_params.append(normalized_practice_heads)
    if normalized_geo_heads:
        revenue_where.append("lower(trim(coalesce(r.geo_head, ''))) = any(%s)")
        revenue_params.append(normalized_geo_heads)

    stored_where: list[str] = []
    stored_params: list[Any] = []
    if normalized_bdms:
        stored_where.append("lower(trim(coalesce(cwd.bdm, ''))) = any(%s)")
        stored_params.append(normalized_bdms)
    if normalized_practice_heads:
        stored_where.append("lower(trim(coalesce(cwd.practice_head, ''))) = any(%s)")
        stored_params.append(normalized_practice_heads)
    if normalized_geo_heads:
        stored_where.append("lower(trim(coalesce(cwd.geo_head, ''))) = any(%s)")
        stored_params.append(normalized_geo_heads)

    revenue_where_sql = f"and {' and '.join(revenue_where)}" if revenue_where else ""
    stored_where_sql = f"where {' and '.join(stored_where)}" if stored_where else ""

    with open_database_connection(require=True) as connection:
        assert connection is not None
        with connection.cursor() as cursor:
            cursor.execute(
                f"""
                select distinct
                    coalesce(nullif(trim(r.customer_name), ''), '') as customer_name,
                    coalesce(nullif(trim(r.bdm), ''), '') as bdm,
                    coalesce(nullif(trim(r.practice_head), ''), '') as practice_head,
                    coalesce(nullif(trim(r.geo_head), ''), '') as geo_head
                from rapid_revenue_records r
                join rapid_revenue_uploads u on u.id = r.upload_id
                where u.is_active = true
                  and nullif(trim(coalesce(r.customer_name, '')), '') is not null
                  {revenue_where_sql}
                order by 1, 2, 3, 4
                """,
                revenue_params,
            )
            base_rows = cursor.fetchall()

            cursor.execute(
                f"""
                select
                    cwd.customer_name,
                    cwd.bdm,
                    cwd.practice_head,
                    cwd.geo_head,
                    cwd.month_label,
                    cwd.working_days,
                    cwd.updated_by,
                    cwd.updated_at
                from rapid_customer_working_days cwd
                {stored_where_sql}
                order by lower(cwd.customer_name), lower(coalesce(cwd.bdm, '')), cwd.month_label
                """,
                stored_params,
            )
            stored_rows = cursor.fetchall()

    working_days_by_scope: dict[tuple[str, str, str, str, str], int] = {}
    updated_meta_by_scope: dict[tuple[str, str, str, str], tuple[str, Any]] = {}
    for row in stored_rows:
        scope_key = _build_customer_scope_key(
            customer_name=row.get("customer_name"),
            bdm=row.get("bdm"),
            practice_head=row.get("practice_head"),
            geo_head=row.get("geo_head"),
        )
        month_label = str(row.get("month_label") or "").strip()
        if month_label not in MONTH_KEY_BY_LABEL:
            continue
        working_days_by_scope[(*scope_key, month_label)] = max(
            0,
            min(31, int(row.get("working_days") or DEFAULT_WORKING_DAYS)),
        )
        updated_meta_by_scope[scope_key] = (
            str(row.get("updated_by") or ""),
            row.get("updated_at"),
        )

    payload_rows: list[dict[str, Any]] = []
    customer_filters: set[str] = set()
    bdm_filters: set[str] = set()
    practice_filters: set[str] = set()
    geo_filters: set[str] = set()

    for row in base_rows:
        customer_name = str(row.get("customer_name") or "").strip()
        bdm = str(row.get("bdm") or "").strip()
        practice_head = str(row.get("practice_head") or "").strip()
        geo_head = str(row.get("geo_head") or "").strip()
        scope_key = _build_customer_scope_key(
            customer_name=customer_name,
            bdm=bdm,
            practice_head=practice_head,
            geo_head=geo_head,
        )
        updated_by, updated_at = updated_meta_by_scope.get(scope_key, ("", None))
        working_days = {
            month_label: working_days_by_scope.get((*scope_key, month_label), DEFAULT_WORKING_DAYS)
            for month_label in months
        }
        payload_rows.append(
            {
                "customerName": customer_name,
                "bdm": bdm,
                "practiceHead": practice_head,
                "geoHead": geo_head,
                "workingDays": working_days,
                "updatedBy": updated_by,
                "updatedAt": _serialize_timestamp(updated_at),
            }
        )
        if customer_name:
            customer_filters.add(customer_name)
        if bdm:
            bdm_filters.add(bdm)
        if practice_head:
            practice_filters.add(practice_head)
        if geo_head:
            geo_filters.add(geo_head)

    return {
        "months": months,
        "rows": payload_rows,
        "filters": {
            "customers": sorted(customer_filters),
            "bdms": sorted(bdm_filters),
            "practiceHeads": sorted(practice_filters),
            "geoHeads": sorted(geo_filters),
        },
    }


def save_customer_working_days(
    rows: list[dict[str, Any]],
    *,
    updated_by: str = "admin-settings",
    allowed_bdms: list[str] | None = None,
    allowed_practice_heads: list[str] | None = None,
    allowed_geo_heads: list[str] | None = None,
) -> dict[str, Any]:
    ensure_postgres_schema()
    months = list(SUPPORTED_FORECAST_MONTHS)
    normalized_allowed_bdms = set(_normalize_scope_values(allowed_bdms))
    normalized_allowed_practices = set(_normalize_scope_values(allowed_practice_heads))
    normalized_allowed_geo_heads = set(_normalize_scope_values(allowed_geo_heads))

    scoped_rows: list[tuple[str, str | None, str | None, str | None, str, int]] = []
    scoped_keys: set[tuple[str, str, str, str]] = set()

    for entry in rows:
        customer_name = _clean_text(entry.get("customerName"))
        if not customer_name:
            raise HTTPException(status_code=400, detail="Customer name is required for working-day rows.")
        bdm = _clean_text(entry.get("bdm")) or None
        practice_head = _clean_text(entry.get("practiceHead")) or None
        geo_head = _clean_text(entry.get("geoHead")) or None

        if normalized_allowed_bdms and str(bdm or "").strip().lower() not in normalized_allowed_bdms:
            raise HTTPException(status_code=403, detail="A customer row is outside your BDM scope.")
        if normalized_allowed_practices and str(practice_head or "").strip().lower() not in normalized_allowed_practices:
            raise HTTPException(status_code=403, detail="A customer row is outside your practice scope.")
        if normalized_allowed_geo_heads and str(geo_head or "").strip().lower() not in normalized_allowed_geo_heads:
            raise HTTPException(status_code=403, detail="A customer row is outside your geo scope.")

        working_days_map = entry.get("workingDays")
        if not isinstance(working_days_map, dict):
            raise HTTPException(status_code=400, detail="Each customer row must include workingDays.")

        scope_key = _build_customer_scope_key(
            customer_name=customer_name,
            bdm=bdm,
            practice_head=practice_head,
            geo_head=geo_head,
        )
        scoped_keys.add(scope_key)

        for month_label in months:
            if month_label not in working_days_map:
                raise HTTPException(
                    status_code=400,
                    detail=f"Missing working days for {customer_name} in {month_label}.",
                )
            try:
                working_days = int(working_days_map[month_label])
            except (TypeError, ValueError) as error:
                raise HTTPException(
                    status_code=400,
                    detail=f"Working days for {customer_name} in {month_label} must be a number.",
                ) from error
            if working_days < 0 or working_days > 31:
                raise HTTPException(
                    status_code=400,
                    detail=f"Working days for {customer_name} in {month_label} must be between 0 and 31.",
                )
            scoped_rows.append(
                (customer_name, bdm, practice_head, geo_head, month_label, working_days)
            )

    now_iso = utc_now_iso()
    with open_database_connection(require=True) as connection:
        assert connection is not None
        with connection.cursor() as cursor:
            for customer_name, bdm, practice_head, geo_head in scoped_keys:
                cursor.execute(
                    """
                    delete from rapid_customer_working_days
                    where lower(customer_name) = %s
                      and lower(coalesce(bdm, '')) = %s
                      and lower(coalesce(practice_head, '')) = %s
                      and lower(coalesce(geo_head, '')) = %s
                    """,
                    (customer_name, bdm, practice_head, geo_head),
                )
            if scoped_rows:
                cursor.executemany(
                    """
                    insert into rapid_customer_working_days (
                        id,
                        customer_name,
                        bdm,
                        practice_head,
                        geo_head,
                        month_label,
                        working_days,
                        updated_by,
                        updated_at
                    )
                    values (%s, %s, %s, %s, %s, %s, %s, %s, %s::timestamptz)
                    """,
                    [
                        (
                            str(uuid4()),
                            customer_name,
                            bdm,
                            practice_head,
                            geo_head,
                            month_label,
                            working_days,
                            updated_by,
                            now_iso,
                        )
                        for customer_name, bdm, practice_head, geo_head, month_label, working_days in scoped_rows
                    ],
                )
        connection.commit()

    payload = get_customer_working_days(
        bdms=allowed_bdms,
        practice_heads=allowed_practice_heads,
        geo_heads=allowed_geo_heads,
    )
    payload["savedAt"] = now_iso
    return payload


def get_forecast_control_settings() -> dict[str, Any]:
    ensure_postgres_schema()
    with open_database_connection(require=True) as connection:
        assert connection is not None
        with connection.cursor() as cursor:
            cursor.execute(
                """
                select
                    lockin_day,
                    lockout_day,
                    lockin_date,
                    lockout_date,
                    rollout_start_month,
                    updated_by,
                    updated_at
                from rapid_forecast_controls
                where id = 'default'
                limit 1
                """
            )
            row = cursor.fetchone()

    if not row:
        return _build_forecast_control_payload(
            lockin_day=DEFAULT_LOCKIN_DAY,
            lockout_day=DEFAULT_LOCKOUT_DAY,
            lockin_date=None,
            lockout_date=None,
            rollout_start_month=DEFAULT_ROLLOUT_START_MONTH,
            updated_by=None,
            updated_at=None,
        )

    rollout_start_month = str(row.get("rollout_start_month") or DEFAULT_ROLLOUT_START_MONTH)
    if rollout_start_month not in MONTH_KEY_BY_LABEL:
        rollout_start_month = DEFAULT_ROLLOUT_START_MONTH
    lockin_day = int(row.get("lockin_day") or DEFAULT_LOCKIN_DAY)
    lockout_day = int(row.get("lockout_day") or DEFAULT_LOCKOUT_DAY)
    if lockin_day < 1:
        lockin_day = DEFAULT_LOCKIN_DAY
    if lockout_day > 31:
        lockout_day = 31
    if lockout_day < lockin_day:
        lockout_day = lockin_day
    return _build_forecast_control_payload(
        lockin_day=lockin_day,
        lockout_day=lockout_day,
        lockin_date=_coerce_date_input(row.get("lockin_date")),
        lockout_date=_coerce_date_input(row.get("lockout_date")),
        rollout_start_month=rollout_start_month,
        updated_by=str(row.get("updated_by") or "") or None,
        updated_at=row.get("updated_at"),
    )


def _archive_locked_forecast_months(
    cursor: Any,
    *,
    locked_months: list[str],
    archived_by: str,
    archived_at: str,
) -> dict[str, int]:
    snapshot_counts: dict[str, int] = {}
    for month_label in locked_months:
        if month_label not in MONTH_KEY_BY_LABEL:
            continue
        cursor.execute(
            """
            select
                r.id as record_id,
                r.financial_year,
                r.customer_name,
                r.project_name,
                r.ms_ps,
                r.practice_head,
                r.bdm,
                r.geo_head,
                r.vertical,
                r.horizontal,
                f.forecast_value,
                f.billed_hours,
                f.billable_actual_hrs,
                f.submitted_by_user_id,
                f.submitted_by_name,
                f.submitted_at
            from rapid_revenue_records r
            join rapid_revenue_uploads u on u.id = r.upload_id
            left join rapid_forecast_entries f
              on f.record_id = r.id and f.forecast_month = %s
            where u.is_active = true
            order by r.id asc
            """,
            (month_label,),
        )
        rows = cursor.fetchall()
        if not rows:
            snapshot_counts[month_label] = 0
            continue

        cursor.executemany(
            """
            insert into rapid_forecast_month_snapshots (
                id,
                financial_year,
                forecast_month,
                record_id,
                row_snapshot,
                forecast_value,
                billed_hours,
                billable_actual_hrs,
                submitted_by_user_id,
                submitted_by_name,
                submitted_at,
                archived_by,
                archived_at
            )
            values (%s, %s, %s, %s, %s::jsonb, %s, %s, %s, %s, %s, %s, %s, %s::timestamptz)
            on conflict (financial_year, forecast_month, record_id)
            do update set
                row_snapshot = excluded.row_snapshot,
                forecast_value = excluded.forecast_value,
                billed_hours = excluded.billed_hours,
                billable_actual_hrs = excluded.billable_actual_hrs,
                submitted_by_user_id = excluded.submitted_by_user_id,
                submitted_by_name = excluded.submitted_by_name,
                submitted_at = excluded.submitted_at,
                archived_by = excluded.archived_by,
                archived_at = excluded.archived_at
            """,
            [
                (
                    str(uuid4()),
                    str(row.get("financial_year") or ""),
                    month_label,
                    int(row.get("record_id") or 0),
                    json.dumps(
                        {
                            "customerName": str(row.get("customer_name") or ""),
                            "projectName": str(row.get("project_name") or ""),
                            "msps": str(row.get("ms_ps") or ""),
                            "practiceHead": str(row.get("practice_head") or ""),
                            "bdm": str(row.get("bdm") or ""),
                            "geoHead": str(row.get("geo_head") or ""),
                            "vertical": str(row.get("vertical") or ""),
                            "horizontal": str(row.get("horizontal") or ""),
                        }
                    ),
                    _to_decimal(row.get("forecast_value")),
                    _to_decimal(row.get("billed_hours")),
                    _to_decimal(row.get("billable_actual_hrs")),
                    str(row.get("submitted_by_user_id") or "") or None,
                    str(row.get("submitted_by_name") or "") or None,
                    row.get("submitted_at"),
                    archived_by,
                    archived_at,
                )
                for row in rows
            ],
        )
        snapshot_counts[month_label] = len(rows)
    return snapshot_counts


def save_forecast_control_settings(
    lockin_day: int | None,
    lockout_day: int | None,
    rollout_start_month: str,
    lockin_date: str | date | None = None,
    lockout_date: str | date | None = None,
    updated_by: str = "admin-settings",
) -> dict[str, Any]:
    ensure_postgres_schema()

    parsed_lockin_date = _coerce_date_input(lockin_date)
    parsed_lockout_date = _coerce_date_input(lockout_date)
    if bool(parsed_lockin_date) != bool(parsed_lockout_date):
        raise HTTPException(status_code=400, detail="Choose both lock-in and lock-out dates.")
    if parsed_lockin_date and parsed_lockout_date and parsed_lockout_date < parsed_lockin_date:
        raise HTTPException(status_code=400, detail="Lock-out date must be on or after lock-in date.")

    resolved_lockin_day = int(parsed_lockin_date.day if parsed_lockin_date else lockin_day or DEFAULT_LOCKIN_DAY)
    resolved_lockout_day = int(parsed_lockout_date.day if parsed_lockout_date else lockout_day or DEFAULT_LOCKOUT_DAY)
    if resolved_lockin_day < 1 or resolved_lockin_day > 31:
        raise HTTPException(status_code=400, detail="Lock-in day must be between 1 and 31.")
    if resolved_lockout_day < 1 or resolved_lockout_day > 31:
        raise HTTPException(status_code=400, detail="Lock-out day must be between 1 and 31.")
    if resolved_lockout_day < resolved_lockin_day:
        raise HTTPException(status_code=400, detail="Lock-out day must be on or after lock-in day.")
    normalized_rollout = str(rollout_start_month or "").strip()
    if normalized_rollout not in MONTH_KEY_BY_LABEL:
        raise HTTPException(status_code=400, detail="Choose a supported rollout start month.")

    now_iso = utc_now_iso()
    archived_counts: dict[str, int] = {}
    with open_database_connection(require=True) as connection:
        assert connection is not None
        with connection.cursor() as cursor:
            cursor.execute(
                """
                update rapid_forecast_controls
                set
                    lockin_day = %s,
                    lockout_day = %s,
                    lockin_date = %s,
                    lockout_date = %s,
                    rollout_start_month = %s,
                    updated_by = %s,
                    updated_at = %s::timestamptz
                where id = 'default'
                """,
                (
                    resolved_lockin_day,
                    resolved_lockout_day,
                    parsed_lockin_date,
                    parsed_lockout_date,
                    normalized_rollout,
                    updated_by,
                    now_iso,
                ),
            )
            if int(cursor.rowcount or 0) == 0:
                cursor.execute(
                    """
                    insert into rapid_forecast_controls (
                        id,
                        lockin_day,
                        lockout_day,
                        lockin_date,
                        lockout_date,
                        rollout_start_month,
                        updated_by,
                        updated_at
                    )
                    values ('default', %s, %s, %s, %s, %s, %s, %s::timestamptz)
                    """,
                    (
                        resolved_lockin_day,
                        resolved_lockout_day,
                        parsed_lockin_date,
                        parsed_lockout_date,
                        normalized_rollout,
                        updated_by,
                        now_iso,
                    ),
                )
            payload = _build_forecast_control_payload(
                lockin_day=resolved_lockin_day,
                lockout_day=resolved_lockout_day,
                lockin_date=parsed_lockin_date,
                lockout_date=parsed_lockout_date,
                rollout_start_month=normalized_rollout,
                updated_by=updated_by,
                updated_at=now_iso,
            )
            archived_counts = _archive_locked_forecast_months(
                cursor,
                locked_months=list(payload.get("lockedMonths") or []),
                archived_by=updated_by,
                archived_at=now_iso,
            )
        connection.commit()
    response = get_forecast_control_settings()
    response["archivedMonths"] = archived_counts
    return response


