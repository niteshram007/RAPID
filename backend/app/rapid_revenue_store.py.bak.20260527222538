def _build_raw_payload_from_values(values: dict[str, Any]) -> dict[str, Any]:
    payload: dict[str, Any] = {}
    for field in RAPID_REVENUE_FIELD_SPECS:
        value = values.get(field.key)
        if field.kind == "numeric":
            payload[field.label] = _to_float(value)
        elif field.kind == "date":
            payload[field.label] = _serialize_date(value)
        else:
            payload[field.label] = str(value or "")
    return payload


def _recalculate_revenue_period_totals(values: dict[str, Any]) -> None:
    for quarter_key, month_keys in QUARTER_MONTH_KEYS.items():
        values[quarter_key] = sum(_to_float(values.get(month_key)) for month_key in month_keys)
    values["fy"] = sum(
        _to_float(values.get(month_key))
        for month_key in MONTH_KEY_BY_LABEL.values()
    )


def _split_reassignment_values(
    source_values: dict[str, Any],
    *,
    future_month_keys: list[str],
) -> tuple[dict[str, Any], dict[str, Any]]:
    old_values = dict(source_values)
    new_values = dict(source_values)
    future_month_key_set = set(future_month_keys)
    for month_key in MONTH_KEY_BY_LABEL.values():
        if month_key in future_month_key_set:
            old_values[month_key] = 0
        else:
            new_values[month_key] = 0
    _recalculate_revenue_period_totals(old_values)
    _recalculate_revenue_period_totals(new_values)
    return old_values, new_values


def _merge_assignment_metadata(
    payload: Any,
    metadata: dict[str, Any],
) -> dict[str, Any]:
    if isinstance(payload, str):
        try:
            payload = json.loads(payload)
        except json.JSONDecodeError:
            payload = {}
    if not isinstance(payload, dict):
        payload = {}
    next_payload = dict(payload)
    next_payload["Assignment Split"] = metadata
    return next_payload


def _read_assignment_metadata(payload: Any) -> dict[str, Any]:
    if isinstance(payload, str):
        try:
            payload = json.loads(payload)
        except json.JSONDecodeError:
            payload = {}
    if not isinstance(payload, dict):
        return {}
    metadata = payload.get("Assignment Split")
    return metadata if isinstance(metadata, dict) else {}


def _clear_assignment_metadata(payload: Any) -> dict[str, Any]:
    if isinstance(payload, str):
        try:
            payload = json.loads(payload)
        except json.JSONDecodeError:
            payload = {}
    if not isinstance(payload, dict):
        return {}
    next_payload = dict(payload)
    next_payload.pop("Assignment Split", None)
    return next_payload


def _overlay_payload_with_values(
    payload: Any,
    values: dict[str, Any],
) -> dict[str, Any]:
    next_payload = _clear_assignment_metadata(payload)
    for field in RAPID_REVENUE_FIELD_SPECS:
        value = values.get(field.key)
        if field.kind == "numeric":
            next_payload[field.label] = _to_float(value)
        elif field.kind == "date":
            next_payload[field.label] = _serialize_date(value)
        else:
            next_payload[field.label] = str(value or "")
    return next_payload


def _read_local_rbac_store() -> dict[str, Any]:
    store_path = ROOT_DIR / "data" / "rbac-store.json"
    if not store_path.exists():
        return {}
    try:
        payload = json.loads(store_path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return {}
    return payload if isinstance(payload, dict) else {}


def _split_store_scope_values(value: Any) -> list[str]:
    raw_value = str(value or "")
    if not raw_value.strip():
        return []
    normalized_text = raw_value
    for separator in (",", ";", "|"):
        normalized_text = normalized_text.replace(separator, "\n")
    unique: dict[str, str] = {}
    for entry in normalized_text.splitlines():
        candidate = entry.strip()
        if not candidate or candidate.lower() == "all":
            continue
        key = candidate.lower()
        if key not in unique:
            unique[key] = candidate
    return list(unique.values())


def _list_configured_user_options(role_id: str, field: str, fallback_fields: tuple[str, ...]) -> list[str]:
    store = _read_local_rbac_store()
    unique: dict[str, str] = {}

    def add(candidate: Any) -> None:
        value = str(candidate or "").strip()
        if not value:
            return
        key = value.lower()
        if key not in unique:
            unique[key] = value

    for user in store.get("users", []):
        if not isinstance(user, dict):
            continue
        role_ids = [
            str(user.get("roleId") or "").strip().lower(),
            *[
                str(role_value).strip().lower()
                for role_value in user.get("roleIds", [])
                if str(role_value).strip()
            ],
        ]
        if role_id not in role_ids:
            continue
        for value in _split_store_scope_values(user.get(field)):
            add(value)
        for fallback_field in fallback_fields:
            fallback_value = str(user.get(fallback_field) or "").strip()
            if fallback_value:
                add(fallback_value)

    return sorted(unique.values(), key=lambda item: item.lower())


def _list_configured_bdm_options() -> list[str]:
    return _list_configured_user_options("bdm", "bdm", ("name",))


def _list_configured_practice_head_options() -> list[str]:
    return _list_configured_user_options("practice-head", "practiceHead", ("practice", "name"))


def _list_configured_geo_head_options() -> list[str]:
    store = _read_local_rbac_store()
    unique: dict[str, str] = {}

    def add(candidate: Any) -> None:
        value = str(candidate or "").strip()
        if not value:
            return
        key = value.lower()
        if key not in unique:
            unique[key] = value

    catalogs = store.get("catalogs")
    if isinstance(catalogs, dict):
        for value in catalogs.get("geos", []):
            add(value)

    for user in store.get("users", []):
        if not isinstance(user, dict):
            continue
        role_ids = [
            str(user.get("roleId") or "").strip().lower(),
            *[
                str(role_id).strip().lower()
                for role_id in user.get("roleIds", [])
                if str(role_id).strip()
            ],
        ]
        if "geo-head" in role_ids:
            for value in _split_store_scope_values(
                user.get("geoHeadScopeGeoHeads") or user.get("geoHead") or user.get("geo")
            ):
                add(value)

    return sorted(unique.values(), key=lambda item: item.lower())


def _is_geo_head_revert_to_original(
    payload: Any,
    *,
    current_geo_head: str,
    target_geo_head: str,
) -> bool:
    metadata = _read_assignment_metadata(payload)
    if str(metadata.get("type") or "").strip().lower() != "geo_head":
        return False
    original_geo_head = str(metadata.get("from") or "").strip().lower()
    assigned_geo_head = str(metadata.get("to") or "").strip().lower()
    return (
        bool(original_geo_head)
        and original_geo_head == str(target_geo_head or "").strip().lower()
        and assigned_geo_head == str(current_geo_head or "").strip().lower()
    )


def _restore_geo_head_reassignment(
    *,
    cursor: Any,
    source_row: dict[str, Any],
    source_values: dict[str, Any],
    future_months: list[str],
    future_month_keys: list[str],
    update_month_columns: list[str],
) -> tuple[int, int]:
    metadata = _read_assignment_metadata(source_row.get("raw_payload"))
    source_record_id = int(source_row.get("id") or 0)
    original_record_id = int(metadata.get("sourceRecordId") or 0)
    if source_record_id <= 0 or original_record_id <= 0:
        raise HTTPException(status_code=400, detail="Unable to locate the original Geo Head allocation row.")

    cursor.execute(
        """
        select r.*
        from rapid_revenue_records r
        join rapid_revenue_uploads u on u.id = r.upload_id
        where r.id = %s and u.is_active = true
        limit 1
        """,
        (original_record_id,),
    )
    original_row = cursor.fetchone()
    if not original_row:
        raise HTTPException(status_code=404, detail="Original Geo Head allocation row was not found.")

    original_values = {
        field.key: original_row.get(field.key)
        for field in RAPID_REVENUE_FIELD_SPECS
    }
    restored_values = dict(original_values)
    for month_key in future_month_keys:
        restored_values[month_key] = source_values.get(month_key)
    _recalculate_revenue_period_totals(restored_values)
    restored_payload = _overlay_payload_with_values(original_row.get("raw_payload"), restored_values)

    cursor.execute(
        f"""
        update rapid_revenue_records
        set {", ".join([f"{column} = %s" for column in update_month_columns[:-1]])},
            raw_payload = %s::jsonb
        where id = %s
        """,
        (
            *[restored_values.get(column) for column in update_month_columns[:-1]],
            json.dumps(restored_payload),
            original_record_id,
        ),
    )

    cursor.execute(
        """
        select
            upload_id,
            financial_year,
            forecast_month,
            budget_value,
            forecast_value,
            billed_hours,
            billable_actual_hrs,
            submitted_by_user_id,
            submitted_by_name,
            submitted_at
        from rapid_forecast_entries
        where record_id = %s and forecast_month = any(%s)
        """,
        (source_record_id, future_months),
    )
    moved_entries = cursor.fetchall()
    if moved_entries:
        cursor.executemany(
            """
            insert into rapid_forecast_entries (
                id,
                upload_id,
                record_id,
                financial_year,
                forecast_month,
                budget_value,
                forecast_value,
                billed_hours,
                billable_actual_hrs,
                submitted_by_user_id,
                submitted_by_name,
                submitted_at
            )
            values (%s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s)
            on conflict (record_id, forecast_month)
            do update set
                budget_value = excluded.budget_value,
                forecast_value = excluded.forecast_value,
                billed_hours = excluded.billed_hours,
                billable_actual_hrs = excluded.billable_actual_hrs,
                submitted_by_user_id = excluded.submitted_by_user_id,
                submitted_by_name = excluded.submitted_by_name,
                submitted_at = excluded.submitted_at
            """,
            [
                (
                    str(uuid4()),
                    row.get("upload_id"),
                    original_record_id,
                    row.get("financial_year"),
                    row.get("forecast_month"),
                    row.get("budget_value"),
                    row.get("forecast_value"),
                    row.get("billed_hours"),
                    row.get("billable_actual_hrs"),
                    row.get("submitted_by_user_id"),
                    row.get("submitted_by_name"),
                    row.get("submitted_at"),
                )
                for row in moved_entries
            ],
        )

    cursor.execute(
        """
        select
            forecast_month,
            submitter_role,
            forecast_value,
            billed_hours,
            billable_actual_hrs,
            submitted_by_user_id,
            submitted_by_name,
            submitted_at
        from rapid_forecast_role_entries
