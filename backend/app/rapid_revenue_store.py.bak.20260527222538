def get_rapid_revenue_overview(filters: dict[str, Any] | None = None) -> dict[str, Any]:
    filters = filters or {}
    fallback_year = str(filters.get("financialYear") or "").strip() or None
    try:
        ensure_postgres_schema()
        ensure_budget_sync_to_rapid_revenue(filters.get("financialYear"))
        dataset = _get_active_upload_metadata(filters)
    except Exception:
        LOGGER.exception("Rapid revenue overview fallback triggered due to data access failure")
        return _empty_rapid_revenue_overview(fallback_year)

    month_sequence = list(MONTH_KEY_BY_LABEL.keys())
    current_month_label = resolve_current_forecast_month()
    if current_month_label not in MONTH_KEY_BY_LABEL:
        current_month_label = month_sequence[0]
    where_sql, params = _build_where_clause(filters)
    current_month_key = MONTH_KEY_BY_LABEL[current_month_label]
    ytd_month_keys = [
        MONTH_KEY_BY_LABEL[label]
        for label in month_sequence[: month_sequence.index(current_month_label) + 1]
    ]
    ytd_sql = " + ".join(f"coalesce(r.{column_key}, 0)" for column_key in ytd_month_keys) or "0"

    def _resolve_top_group(
        cursor: Any,
        column_name: str,
    ) -> dict[str, Any] | None:
        cursor.execute(
            f"""
            select
                nullif(trim(coalesce(r.{column_name}, '')), '') as label,
                coalesce(sum(coalesce(r.fy, 0)), 0) as total_fy
            from rapid_revenue_records r
            join rapid_revenue_uploads u on u.id = r.upload_id
            where u.is_active = true {where_sql}
            group by 1
            order by total_fy desc, label asc nulls last
            limit 1
            """,
            params,
        )
        row = cursor.fetchone()
        if not row:
            return None
        label = str(row.get("label") or "").strip()
        value = float(row.get("total_fy") or 0.0)
        if not label and value == 0:
            return None
        return {
            "label": label or "(Blank)",
            "value": value,
        }

    try:
        with open_database_connection(require=True) as connection:
            assert connection is not None
            with connection.cursor() as cursor:
                cursor.execute(
                    f"""
                    select
                        count(*) as row_count,
                        count(distinct nullif(trim(coalesce(r.customer_name, '')), '')) as customer_count,
                        count(distinct nullif(trim(coalesce(r.resource_id, '')), '')) as resource_count,
                        coalesce(sum(coalesce(r.fy, 0)), 0) as total_fy,
                        coalesce(sum(coalesce(r.{current_month_key}, 0)), 0) as month_to_date_total,
                        coalesce(sum({ytd_sql}), 0) as year_to_date_total
                    from rapid_revenue_records r
                    join rapid_revenue_uploads u on u.id = r.upload_id
                    where u.is_active = true {where_sql}
                    """,
                    params,
                )
                summary_row = cursor.fetchone() or {}
                top_practice = _resolve_top_group(cursor, "practice_head")
                top_geo_head = _resolve_top_group(cursor, "geo_head")
                top_bdm = _resolve_top_group(cursor, "bdm")
    except Exception:
        LOGGER.exception("Rapid revenue overview fallback triggered during summary query")
        return _empty_rapid_revenue_overview(
            str(dataset.get("financialYear") or fallback_year or "").strip() or None,
        )

    return {
        "rowCount": int(summary_row.get("row_count") or 0),
        "customerCount": int(summary_row.get("customer_count") or 0),
        "resourceCount": int(summary_row.get("resource_count") or 0),
        "totalFY": float(summary_row.get("total_fy") or 0.0),
        "financialYear": dataset.get("financialYear"),
        "currentMonthLabel": current_month_label,
        "monthToDateTotal": float(summary_row.get("month_to_date_total") or 0.0),
        "yearToDateTotal": float(summary_row.get("year_to_date_total") or 0.0),
        "topPractice": top_practice,
        "topGeoHead": top_geo_head,
        "topBDM": top_bdm,
        "latestUploadAt": dataset.get("uploadedAt"),
        "latestUploadName": dataset.get("originalFilename"),
    }


