                    f"{user_name} created renewal row",
                    f"{user_name} created renewal row {created_record_id} from source {record_id}.",
                    "/executive/forecast",
                    now_iso,
                    json.dumps({"sourceRecordId": record_id, "createdRecordId": created_record_id}),
                ),
            )
        connection.commit()

    return {
        "status": "created",
        "recordId": created_record_id,
        "sourceRecordId": record_id,
    }


