def _normalize_new_project_values(values: dict[str, Any]) -> dict[str, Any]:
    if not isinstance(values, dict):
        raise HTTPException(status_code=400, detail="New project values must be an object.")

    header_map: dict[str, str] = {}
    for field in RAPID_REVENUE_FIELD_SPECS:
        for candidate in {field.label, field.key, *field.aliases}:
            normalized = normalize_header(candidate)
            if normalized:
                header_map[normalized] = field.key

    normalized_values: dict[str, Any] = {}
    provided_numeric_keys: set[str] = set()
    for input_key, raw_value in values.items():
        key = header_map.get(normalize_header(str(input_key)))
        if not key:
            continue
        field = RAPID_REVENUE_FIELD_BY_KEY[key]
        if field.kind == "numeric":
            parsed_numeric = _parse_optional_numeric(raw_value)
            normalized_values[key] = parsed_numeric
            if parsed_numeric is not None:
                provided_numeric_keys.add(key)
        elif field.kind == "date":
            normalized_values[key] = _coerce_date_input(raw_value)
        else:
            normalized_values[key] = str(raw_value or "").strip()

    for field in RAPID_REVENUE_FIELD_SPECS:
        if field.kind == "numeric" and normalized_values.get(field.key) is None:
            normalized_values[field.key] = 0.0

    for quarter_key, month_keys in QUARTER_MONTH_KEYS.items():
        if quarter_key not in provided_numeric_keys:
            normalized_values[quarter_key] = sum(
                _to_float(normalized_values.get(month_key))
                for month_key in month_keys
            )

    if "fy" not in provided_numeric_keys:
        normalized_values["fy"] = sum(
            _to_float(normalized_values.get(month_key))
            for month_key in MONTH_KEY_BY_LABEL.values()
        )

    return normalized_values


def _coerce_date_input(value: Any) -> date | None:
    if value in (None, ""):
        return None
    if isinstance(value, datetime):
        return value.date()
    if isinstance(value, date):
        return value

    text = str(value).strip()
    if not text:
        return None
    for fmt in (
        "%Y-%m-%d",
        "%d-%m-%Y",
        "%d/%m/%Y",
        "%m/%d/%Y",
        "%d-%b-%Y",
        "%d %b %Y",
        "%d.%m.%Y",
    ):
        try:
            return datetime.strptime(text, fmt).date()
        except ValueError:
            continue
    raise HTTPException(status_code=400, detail=f"Invalid date value: {text}.")


def _build_where_clause(
    filters: dict[str, Any],
    query_map: dict[str, str] = FILTER_QUERY_MAP,
) -> tuple[str, list[Any]]:
    clauses: list[str] = []
    params: list[Any] = []
    for filter_key, column in query_map.items():
        value = filters.get(filter_key)
        if isinstance(value, list) and value:
            normalized_values = [
                str(item).strip().lower()
                for item in value
                if str(item).strip()
            ]
            if normalized_values:
                clauses.append(f"and lower(trim(coalesce({column}::text, ''))) = any(%s)")
                params.append(normalized_values)
        elif isinstance(value, str) and value.strip():
            clauses.append(f"and lower(trim(coalesce({column}::text, ''))) = %s")
            params.append(value.strip().lower())
    return " " + " ".join(clauses) if clauses else "", params


def _get_active_upload_metadata(filters: dict[str, Any]) -> dict[str, Any]:
    ensure_postgres_schema()
    ensure_budget_sync_to_rapid_revenue(filters.get("financialYear"))
    where_sql = ""
    params: list[Any] = []
    if filters.get("financialYear"):
        where_sql = "and financial_year = %s"
        params.append(filters["financialYear"])

    with open_database_connection(require=True) as connection:
        assert connection is not None
        with connection.cursor() as cursor:
            cursor.execute(
                f"""
                select id::text as id, financial_year, original_filename, uploaded_at
                from rapid_revenue_uploads
                where is_active = true {where_sql}
                order by uploaded_at desc
                limit 1
                """,
                params,
            )
            row = cursor.fetchone()

    if not row:
        return {
            "uploadId": None,
            "financialYear": filters.get("financialYear"),
            "originalFilename": None,
            "uploadedAt": None,
        }

    return {
        "uploadId": row.get("id"),
        "financialYear": row.get("financial_year"),
        "originalFilename": row.get("original_filename"),
        "uploadedAt": _serialize_timestamp(row.get("uploaded_at")),
    }


def _serialize_public_row(row: dict[str, Any]) -> dict[str, Any]:
    payload: dict[str, Any] = {}
    for field in RAPID_REVENUE_FIELD_SPECS:
        value = row.get(field.key)
        if field.kind == "numeric":
            payload[field.label] = _to_float(value)
        elif field.kind == "date":
            payload[field.label] = _serialize_date(value)
        else:
            payload[field.label] = str(value or "")
    return payload


def _serialize_date(value: Any) -> str | None:
    if value is None:
        return None
    if isinstance(value, datetime):
        return value.date().isoformat()
    if isinstance(value, date):
        return value.isoformat()
    text = str(value).strip()
    return text or None


def _serialize_timestamp(value: Any) -> str | None:
    if value is None:
        return None
    if isinstance(value, datetime):
        return value.isoformat().replace("+00:00", "Z")
    text = str(value).strip()
    return text or None


def _parse_numeric(value: Any) -> float:
    if value in (None, ""):
        return 0.0
    if isinstance(value, (int, float)):
        return float(value)
    cleaned = str(value).replace(",", "").strip()
    return float(cleaned or 0)


def _parse_optional_numeric(value: Any) -> float | None:
    if value in (None, ""):
        return None
    return _parse_numeric(value)


def _to_decimal(value: Any) -> Decimal:
    if isinstance(value, Decimal):
        return value
    if value in (None, ""):
        return Decimal("0")
    return Decimal(str(value))


def _to_float(value: Any) -> float:
    if value is None:
        return 0.0
    if isinstance(value, Decimal):
        return float(value)
    if isinstance(value, (int, float)):
        return float(value)
    try:
        return float(str(value))
    except ValueError:
        return 0.0

