    with open_database_connection(require=True) as connection:
        assert connection is not None
        with connection.cursor() as cursor:
            cursor.execute(
                """
                select r.id, r.bdm, r.source_sheet
                from rapid_revenue_records r
                join rapid_revenue_uploads u on u.id = r.upload_id
                where r.id = %s and u.is_active = true
                limit 1
                """,
                (record_id,),
            )
            target_row = cursor.fetchone()
            if not target_row:
                raise HTTPException(status_code=404, detail="Forecast row not found.")

            source_sheet = str(target_row.get("source_sheet") or "")
            if not source_sheet.startswith("manual-"):
                raise HTTPException(
                    status_code=400,
                    detail="Only manually created renewal/new project rows can be deleted.",
                )

            scoped_bdm = str(target_row.get("bdm") or "").strip().lower()
            if normalized_bdm_scope and scoped_bdm not in normalized_bdm_scope:
                raise HTTPException(
                    status_code=403,
                    detail="This row is outside the signed-in BDM scope.",
                )

            cursor.execute("delete from rapid_revenue_records where id = %s", (record_id,))
            if cursor.rowcount == 0:
                raise HTTPException(status_code=404, detail="Forecast row not found.")

            cursor.execute(
                """
                insert into rapid_notifications (
                    id,
                    category,
                    audience_role,
                    audience_user_id,
                    title,
                    message,
                    link,
                    created_at,
                    metadata
                )
                values (%s, %s, %s, %s, %s, %s, %s, %s::timestamptz, %s::jsonb)
                """,
                (
                    str(uuid4()),
                    "forecast_row_deleted",
                    "executive",
                    None,
                    f"{user_name} deleted manual forecast row",
                    f"{user_name} deleted manual forecast row {record_id}.",
                    "/executive/forecast",
                    now_iso,
                    json.dumps({"deletedRecordId": record_id}),
                ),
            )
        connection.commit()

    return {
        "status": "deleted",
        "recordId": record_id,
    }


def clear_all_recorded_forecasts(
    user_id: str,
    user_name: str,
) -> dict[str, Any]:
    ensure_postgres_schema()
    with open_database_connection(require=True) as connection:
        assert connection is not None
        with connection.cursor() as cursor:
            cursor.execute("select count(*) as total from rapid_forecast_entries")
            primary_count = int((cursor.fetchone() or {}).get("total") or 0)
            cursor.execute("select count(*) as total from rapid_forecast_role_entries")
            role_count = int((cursor.fetchone() or {}).get("total") or 0)
            cursor.execute("delete from rapid_forecast_role_entries")
            cursor.execute("delete from rapid_forecast_entries")
