def _forecast_overview_wide_to_long(frame: pd.DataFrame) -> pd.DataFrame:
    if frame.empty:
        return pd.DataFrame(columns=[*OVERVIEW_FORECAST_DIMENSION_COLUMNS, "month", "amount"])

    month_frames: list[pd.DataFrame] = []
    for month, month_column in OVERVIEW_FORECAST_MONTH_COLUMNS.items():
        scoped = frame[[*OVERVIEW_FORECAST_DIMENSION_COLUMNS, month_column]].copy()
        scoped["month"] = month
        scoped["amount"] = pd.to_numeric(scoped[month_column], errors="coerce").fillna(0.0)
        scoped = scoped.drop(columns=[month_column])
        month_frames.append(scoped)

    if not month_frames:
        return pd.DataFrame(columns=[*OVERVIEW_FORECAST_DIMENSION_COLUMNS, "month", "amount"])

    merged = pd.concat(month_frames, ignore_index=True)
    return _normalize_overview_frame(merged)


def _build_effective_forecast_overview_frame(
    forecast_upload_wide_df: pd.DataFrame,
    forecast_submission_df: pd.DataFrame,
) -> pd.DataFrame:
    submission = _normalize_overview_frame(forecast_submission_df)
    upload_long = _forecast_overview_wide_to_long(forecast_upload_wide_df)

    if upload_long.empty:
        return submission
    if submission.empty:
        return upload_long

    key_columns = [*OVERVIEW_FORECAST_DIMENSION_COLUMNS, "month"]
    upload_indexed = upload_long.set_index(key_columns)
    submission_indexed = submission.set_index(key_columns)
    upload_without_submission = upload_indexed.loc[
        ~upload_indexed.index.isin(submission_indexed.index)
    ]
    merged = pd.concat([upload_without_submission, submission_indexed], axis=0)
    merged = merged.reset_index()
    merged["amount"] = pd.to_numeric(merged["amount"], errors="coerce").fillna(0.0)
    return _normalize_overview_frame(merged)


def _ensure_actual_revenue_for_year(connection: Any, financial_year: str) -> None:
    if not financial_year:
        return

    now = time.monotonic()
    with connection.cursor() as cursor:
        cursor.execute(
            "alter table if exists actual_revenue add column if not exists ocn_number text"
        )
        cursor.execute(
            """
            create index if not exists actual_revenue_ocn_idx
              on actual_revenue (lower(coalesce(ocn_number, '')))
            """
        )
        cursor.execute(
            """
            select
                u.id::text as upload_id,
                coalesce(u.upload_month, '') as upload_month
            from global_revenue_uploads u
            where u.financial_year = %s
              and u.is_active = true
            order by
                case lower(trim(coalesce(u.upload_month, '')))
                    when 'apr' then 0
                    when 'may' then 1
                    when 'jun' then 2
                    when 'jul' then 3
                    when 'aug' then 4
                    when 'sep' then 5
                    when 'oct' then 6
                    when 'nov' then 7
                    when 'dec' then 8
                    when 'jan' then 9
                    when 'feb' then 10
                    when 'mar' then 11
                    else -1
                end desc,
                u.uploaded_at desc,
                u.id desc
            limit 1
            """,
            (financial_year,),
        )
        active_upload = cursor.fetchone() or {}
        active_upload_id = str(active_upload.get("upload_id") or "").strip()
        upload_month = str(active_upload.get("upload_month") or "").strip()
        if not active_upload_id:
            _ACTUAL_REFRESH_CHECK_STATE.pop(financial_year, None)
            return
        prior_state = _ACTUAL_REFRESH_CHECK_STATE.get(financial_year)
        if (
            prior_state
            and prior_state[0] == active_upload_id
            and prior_state[1].lower() == upload_month.lower()
            and now - prior_state[2] < ACTUAL_REFRESH_CHECK_TTL_SECONDS
        ):
            return

        cursor.execute(
            """
            select
                count(*) as total_rows,
                count(*) filter (where uploaded_file_id = %s::uuid) as active_upload_rows,
                count(*) filter (
                    where lower(left(trim(coalesce(month, '')), 3)) = lower(left(trim(%s), 3))
                ) as active_month_rows
            from actual_revenue
            where fy_year = %s
            """,
            (active_upload_id, str(active_upload.get("upload_month") or ""), financial_year),
        )
        stats = cursor.fetchone() or {}
        total_rows = int(stats.get("total_rows") or 0)
        active_upload_rows = int(stats.get("active_upload_rows") or 0)
        active_month_rows = int(stats.get("active_month_rows") or 0)
        has_month_label = bool(str(active_upload.get("upload_month") or "").strip())
        if total_rows > 0 and active_upload_rows == total_rows and (
            not has_month_label or active_month_rows == total_rows
        ):
            cursor.execute(
                """
                select
                    coalesce(sum(actual_revenue_value), 0) as actual_sum
                from actual_revenue
                where fy_year = %s
                  and uploaded_file_id = %s::uuid
                  and (
                    %s = ''
                    or lower(left(trim(coalesce(month, '')), 3)) = lower(left(trim(%s), 3))
                  )
                """,
                (financial_year, active_upload_id, upload_month, upload_month),
            )
            actual_sum = float((cursor.fetchone() or {}).get("actual_sum") or 0.0)
            cursor.execute(
                """
                select
                    coalesce(
                        sum(
                            coalesce(
                                nullif(
                                    regexp_replace(
                                        coalesce(
                                            r.raw_payload->>'YTD Revenue$',
                                            r.raw_payload->>'YTD Revenue',
                                            r.raw_payload->>'YTD Revenue USD',
                                            r.raw_payload->>'YTD Revenue$ (USD)',
                                            r.raw_payload->>'YTD Revenue ($)',
                                            r.raw_payload->>'YTDrevenue$',
                                            r.raw_payload->>'YTDRevenue$',
                                            r.raw_payload->>'YTDrevenue',
                                            r.raw_payload->>'YTDRevenue',
                                            ''
                                        ),
                                        '[^0-9.\\-]',
                                        '',
                                        'g'
                                    ),
                                    ''
                                )::numeric,
                                0
                            )
                        ),
                        0
                    ) as raw_ytd_sum
                from global_revenue_records r
                where r.upload_id = %s::uuid
                """,
                (active_upload_id,),
            )
            raw_ytd_sum = float((cursor.fetchone() or {}).get("raw_ytd_sum") or 0.0)
            cursor.execute(
                """
                select
                    count(*) filter (
                        where upper(coalesce(ms_ps, '')) = 'MS'
                          and nullif(trim(coalesce(ocn_number, '')), '') is not null
                    ) as actual_ms_ocn_count,
                    count(*) filter (
                        where upper(coalesce(ms_ps, '')) = 'PS'
                          and nullif(trim(coalesce(emp_id, '')), '') is not null
                    ) as actual_ps_emp_count
                from actual_revenue
                where fy_year = %s
                  and uploaded_file_id = %s::uuid
                  and (
                    %s = ''
                    or lower(left(trim(coalesce(month, '')), 3)) = lower(left(trim(%s), 3))
                  )
                """,
                (financial_year, active_upload_id, upload_month, upload_month),
            )
            actual_identifier_stats = cursor.fetchone() or {}
            actual_ms_ocn_count = int(actual_identifier_stats.get("actual_ms_ocn_count") or 0)
            actual_ps_emp_count = int(actual_identifier_stats.get("actual_ps_emp_count") or 0)

            cursor.execute(
                """
                select
                    count(*) filter (
                        where upper(coalesce(r.ms_ps, '')) = 'MS'
                          and nullif(
                            trim(
                                coalesce(
                                    r.ocn_number,
                                    r.raw_payload->>'OCN Number',
                                    r.raw_payload->>'OCN',
                                    r.raw_payload->>'OCN No',
                                    r.raw_payload->>'OCN_NUMBER'
                                )
                            ),
                            ''
                          ) is not null
                    ) as source_ms_ocn_count,
                    count(*) filter (
                        where upper(coalesce(r.ms_ps, '')) = 'PS'
                          and nullif(
                            trim(
                                coalesce(
                                    r.resource_id,
                                    r.raw_payload->>'Emp ID',
                                    r.raw_payload->>'Employee ID',
                                    r.raw_payload->>'Resource ID'
                                )
                            ),
                            ''
                          ) is not null
                    ) as source_ps_emp_count
                from global_revenue_records r
                where r.upload_id = %s::uuid
                """,
                (active_upload_id,),
            )
            source_identifier_stats = cursor.fetchone() or {}
            source_ms_ocn_count = int(source_identifier_stats.get("source_ms_ocn_count") or 0)
            source_ps_emp_count = int(source_identifier_stats.get("source_ps_emp_count") or 0)

            needs_identifier_rebuild = (
                (source_ms_ocn_count > 0 and actual_ms_ocn_count == 0)
                or (source_ps_emp_count > 0 and actual_ps_emp_count == 0)
            )

            if abs(actual_sum - raw_ytd_sum) <= 0.01 and not needs_identifier_rebuild:
                _ACTUAL_REFRESH_CHECK_STATE[financial_year] = (
                    active_upload_id,
                    upload_month,
                    now,
                )
                return

    refresh_actual_revenue(financial_year, connection)
    connection.commit()
    _ACTUAL_REFRESH_CHECK_STATE[financial_year] = (
        active_upload_id,
        upload_month,
        time.monotonic(),
    )


