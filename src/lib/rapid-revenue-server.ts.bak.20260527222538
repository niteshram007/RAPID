function buildWorkspaceComparisonSearch(filters: RapidRevenueScopeFilters = {}) {
  const search = new URLSearchParams();
  if (filters.financialYear) {
    search.set("financialYear", filters.financialYear);
  }
  if (filters.periodFrom) {
    search.set("periodFrom", filters.periodFrom);
  }
  if (filters.periodTo) {
    search.set("periodTo", filters.periodTo);
  }
  (filters.practiceHeads ?? []).forEach((value) => search.append("practices", value));
  (filters.bdms ?? []).forEach((value) => search.append("bdms", value));
  (filters.geoHeads ?? []).forEach((value) => search.append("geoHeads", value));
  (filters.verticals ?? []).forEach((value) => search.append("verticals", value));
  (filters.entities ?? []).forEach((value) => search.append("entities", value));
  (filters.rowUs ?? []).forEach((value) => search.append("geographies", value));
  (filters.customerNames ?? []).forEach((value) => search.append("accounts", value));
  (filters.dealTypes ?? []).forEach((value) => search.append("dealTypes", value));
  (filters.msps ?? []).forEach((value) => search.append("businessTypes", value));
  return search.toString();
}

