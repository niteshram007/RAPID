const BACKEND_API_URL = process.env.BACKEND_API_URL ?? "http://127.0.0.1:8000";
const BACKEND_FETCH_TIMEOUT_MS = Math.max(
  Number(process.env.BACKEND_FETCH_TIMEOUT_MS ?? 30000),
  1000,
);
const BACKEND_RESPONSE_CACHE_TTL_MS = Math.max(
  Number(process.env.RAPID_SERVER_RESPONSE_CACHE_TTL_MS ?? 20000),
  0,
);
const BACKEND_RESPONSE_CACHE_MAX_ENTRIES = Math.max(
  Number(process.env.RAPID_SERVER_RESPONSE_CACHE_MAX_ENTRIES ?? 256),
  64,
);
const backendResponseCache = new Map<
  string,
  { expiresAt: number; savedAt: number; value: unknown }
>();

type RevenueBackendFailureReason = Exclude<RevenueMetaReason, "no_data_period">;
export type RevenueBackendFetchMeta = {
  dataState: "fresh" | "stale" | "fallback";
  reason?: RevenueBackendFailureReason;
  statusCode?: number;
  lastSuccessAt?: string | null;
};

export type RevenueBackendFetchResult<T> = {
  payload: T;
  meta: RevenueBackendFetchMeta;
};

function pruneBackendResponseCache(now: number) {
  for (const [key, entry] of backendResponseCache.entries()) {
    if (entry.expiresAt <= now) {
      backendResponseCache.delete(key);
    }
  }
  while (backendResponseCache.size > BACKEND_RESPONSE_CACHE_MAX_ENTRIES) {
    const oldestKey = backendResponseCache.keys().next().value;
    if (!oldestKey) {
      break;
    }
    backendResponseCache.delete(oldestKey);
  }
}

function mapBackendFailureReason(statusCode: number): RevenueBackendFailureReason {
  if (statusCode === 401) {
    return "unauthorized";
  }
  if (statusCode === 403) {
    return "forbidden";
  }
  if (statusCode === 408 || statusCode === 504) {
    return "timeout";
  }
  return "backend_unavailable";
}

async function fetchRevenueBackendWithMeta<T>(
  path: string,
  fallback: T,
  options?: {
    cacheable?: boolean;
    cacheKey?: string;
  },
): Promise<RevenueBackendFetchResult<T>> {
  const controller = new AbortController();
  const timeout = setTimeout(() => controller.abort(), BACKEND_FETCH_TIMEOUT_MS);
  const session = await getSessionProfile().catch(() => null);
  const cacheable = Boolean(options?.cacheable) && BACKEND_RESPONSE_CACHE_TTL_MS > 0;
  const scopeKey = session
    ? `${session.userId}:${session.role?.id ?? session.roleId ?? "unknown-role"}`
    : "anonymous";
  const responseCacheKey =
    options?.cacheKey && options.cacheKey.trim().length > 0
      ? `${scopeKey}:${options.cacheKey.trim()}`
      : `${scopeKey}:${path}`;
  const now = Date.now();
  const cached = cacheable ? backendResponseCache.get(responseCacheKey) : undefined;
  const cachedTimestamp = cached ? new Date(cached.savedAt).toISOString() : null;

  if (cacheable) {
    if (cached && cached.expiresAt > now) {
      return {
        payload: cached.value as T,
        meta: {
          dataState: "fresh",
          lastSuccessAt: cachedTimestamp,
        },
      };
    }
    if (cached && cached.expiresAt <= now) {
      backendResponseCache.delete(responseCacheKey);
    }
  }

  try {
    const response = await fetch(`${BACKEND_API_URL}${path}`, {
      cache: "no-store",
      headers: session ? buildBackendAuthHeaders(session) : undefined,
      signal: controller.signal,
    });
    if (!response.ok) {
      const reason = mapBackendFailureReason(response.status);
      if (cached) {
        return {
          payload: cached.value as T,
          meta: {
            dataState: "stale",
            reason,
            statusCode: response.status,
            lastSuccessAt: cachedTimestamp,
          },
        };
      }
      return {
        payload: fallback,
        meta: {
          dataState: "fallback",
          reason,
          statusCode: response.status,
          lastSuccessAt: null,
        },
      };
    }
    const body = (await response.json()) as T;
    if (cacheable) {
      const responseSavedAt = Date.now();
      backendResponseCache.set(responseCacheKey, {
        expiresAt: responseSavedAt + BACKEND_RESPONSE_CACHE_TTL_MS,
        savedAt: responseSavedAt,
        value: body,
      });
      pruneBackendResponseCache(responseSavedAt);
    }
    return {
      payload: body,
      meta: {
        dataState: "fresh",
        lastSuccessAt: new Date(Date.now()).toISOString(),
      },
    };
  } catch (error) {
    const reason: RevenueBackendFailureReason =
      controller.signal.aborted ||
      (error instanceof DOMException && error.name === "AbortError")
        ? "timeout"
        : "backend_unavailable";
    if (cached) {
      return {
        payload: cached.value as T,
        meta: {
          dataState: "stale",
          reason,
          lastSuccessAt: cachedTimestamp,
        },
      };
    }
    return {
      payload: fallback,
      meta: {
        dataState: "fallback",
        reason,
        lastSuccessAt: null,
      },
    };
  } finally {
    clearTimeout(timeout);
  }
}

async function fetchRevenueBackend<T>(
  path: string,
  fallback: T,
  options?: {
    cacheable?: boolean;
    cacheKey?: string;
  },
): Promise<T> {
  const result = await fetchRevenueBackendWithMeta(path, fallback, options);
  return result.payload;
}

export function buildRapidRevenueScopeFilters(
  session: SessionProfile,
): RapidRevenueScopeFilters {
  const scope = getRevenueAccessScope(session);
  return {
    practiceHeads: scope.practiceHeads,
    geoHeads: scope.geoHeads,
    bdms: scope.bdms,
    entities: scope.entities,
    verticals: scope.verticals,
  };
}

function mergeScopedValues(requested: string[] | undefined, allowed: string[] | undefined) {
  if (!allowed || allowed.length === 0) {
    return requested;
  }
  if (!requested || requested.length === 0) {
    return allowed;
  }
  const normalizedAllowed = new Map<string, string>();
  for (const value of allowed) {
    const key = value.trim().toLowerCase();
    if (!key || normalizedAllowed.has(key)) {
      continue;
    }
    normalizedAllowed.set(key, value);
  }

  const merged: string[] = [];
  for (const value of requested) {
    const key = value.trim().toLowerCase();
    const canonical = normalizedAllowed.get(key);
    if (canonical) {
      merged.push(canonical);
    }
  }

  return Array.from(new Set(merged));
}

export function mergeScopedRevenueFilters(
  session: SessionProfile,
  requested: RapidRevenueScopeFilters = {},
): RapidRevenueScopeFilters {
  const scope = buildRapidRevenueScopeFilters(session);
  return {
    financialYear: requested.financialYear,
    periodFrom: requested.periodFrom,
    periodTo: requested.periodTo,
    practiceHeads: mergeScopedValues(requested.practiceHeads, scope.practiceHeads),
    bdms: mergeScopedValues(requested.bdms, scope.bdms),
    geoHeads: mergeScopedValues(requested.geoHeads, scope.geoHeads),
    verticals: mergeScopedValues(requested.verticals, scope.verticals),
    horizontals: requested.horizontals,
    msps: requested.msps,
    customerNames: requested.customerNames,
    rowUs: requested.rowUs,
    entities: mergeScopedValues(requested.entities, scope.entities),
    strategicAccounts: requested.strategicAccounts,
    dealTypes: requested.dealTypes,
    eeennns: requested.eeennns,
    projectNames: requested.projectNames,
  };
}

