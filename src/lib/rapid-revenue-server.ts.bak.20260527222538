}

export async function saveForecastDraftSheet(
  session: SessionProfile,
  forecastMonth: string,
  rows: ForecastSubmissionRow[],
) {
  const scope = getRevenueAccessScope(session);
  const response = await fetch(`${BACKEND_API_URL}/api/revenue/forecast-draft`, {
    method: "POST",
    headers: buildBackendAuthHeaders(session, {
      "Content-Type": "application/json",
    }),
    body: JSON.stringify({
      userId: session.userId,
      userName: session.name,
      bdms: scope.bdms,
      submitterRoleId: session.role?.id ?? "bdm",
      forecastMonth,
      rows,
    }),
    cache: "no-store",
    signal: AbortSignal.timeout(BACKEND_FETCH_TIMEOUT_MS),
  });

  if (!response.ok) {
    const payload = (await response.json().catch(() => null)) as
      | { detail?: string }
      | null;
    throw new Error(payload?.detail ?? "Unable to autosave forecast draft.");
  }

  return (await response.json()) as ForecastDraftSaveResponse;
}

