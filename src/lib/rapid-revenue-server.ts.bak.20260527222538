export async function getForecastSheet(
  session: SessionProfile,
  forecastMonth?: string | null,
  msps?: string[],
  selectedBdms?: string[],
  selectedPracticeHeads?: string[],
  financialYear?: string | null,
  previewDrafts = false,
  includeAllMonths = false,
) {
  const scope = getRevenueAccessScope(session);
  const search = new URLSearchParams({
    userId: session.userId,
    userName: session.name,
  });
  scope.bdms.forEach((bdm) => search.append("bdms", bdm));
  scope.practiceHeads.forEach((value) => search.append("practiceHeads", value));
  scope.geoHeads.forEach((value) => search.append("geoHeads", value));
  scope.entities.forEach((value) => search.append("entities", value));
  scope.verticals.forEach((value) => search.append("verticals", value));
  if (forecastMonth) {
    search.set("forecastMonth", forecastMonth);
  }
  if (financialYear) {
    search.set("financialYear", financialYear);
  }
  if (previewDrafts) {
    search.set("previewDrafts", "1");
    search.set("submitterRoleId", session.role?.id ?? "bdm");
  }
  if (includeAllMonths) {
    search.set("includeAllMonths", "1");
  }
  (msps ?? []).forEach((value) => search.append("msps", value));
  mergeScopedValues(selectedBdms, scope.bdms)?.forEach((value) =>
    search.append("selectedBdms", value),
  );
  mergeScopedValues(selectedPracticeHeads, scope.practiceHeads)?.forEach((value) =>
    search.append("selectedPracticeHeads", value),
  );
  return fetchRevenueBackend<ForecastSheetResponse>(
    `/api/revenue/forecast-sheet?${search.toString()}`,
    {
      forecastMonth: forecastMonth ?? "Apr 2026",
      financialYear: null,
      hasActiveUpload: false,
      bdmOptions: [],
      forecastControls: {
        lockinDay: 1,
        lockoutDay: 10,
        rolloutStartMonth: "Apr 2026",
        activeMonth: "Apr 2026",
        visibleMonths: [
          "Apr 2026",
          "May 2026",
          "Jun 2026",
          "Jul 2026",
          "Aug 2026",
          "Sep 2026",
          "Oct 2026",
          "Nov 2026",
          "Dec 2026",
          "Jan 2027",
          "Feb 2027",
          "Mar 2027",
        ],
        lockedMonths: [],
        editableMonths: [
          "Apr 2026",
          "May 2026",
          "Jun 2026",
          "Jul 2026",
          "Aug 2026",
          "Sep 2026",
          "Oct 2026",
          "Nov 2026",
          "Dec 2026",
          "Jan 2027",
          "Feb 2027",
          "Mar 2027",
        ],
        submissionWindowOpen: true,
        updatedBy: null,
        updatedAt: null,
      },
      rows: [],
      monthSnapshots: includeAllMonths ? {} : undefined,
      summary: {
        rowCount: 0,
        submittedRows: 0,
        isPastDue: false,
        dueDay: 10,
        userId: session.userId,
        userName: session.name,
